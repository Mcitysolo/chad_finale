[Unit]
Description=CHAD Kraken Futures public intelligence publisher
After=network.target

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/chad_finale
Environment=PYTHONPATH=/home/ubuntu/chad_finale
ExecStart=/home/ubuntu/chad_finale/venv/bin/python3 -m chad.market_data.kraken_futures_intel_publisher
StandardOutput=journal
StandardError=journal
SyslogIdentifier=chad-kraken-futures-intel-refresh

[Install]
WantedBy=multi-user.target
