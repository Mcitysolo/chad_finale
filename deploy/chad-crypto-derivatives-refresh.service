[Unit]
Description=CHAD crypto derivatives public-data publisher
After=network.target

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/chad_finale
Environment=PYTHONPATH=/home/ubuntu/chad_finale
ExecStart=/home/ubuntu/chad_finale/venv/bin/python3 -m chad.market_data.crypto_derivatives_publisher
StandardOutput=journal
StandardError=journal
SyslogIdentifier=chad-crypto-derivatives-refresh

[Install]
WantedBy=multi-user.target
