[Unit]
Description=CHAD Advisory Pre-Market Refresh
After=network-online.target

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/chad_finale
Environment=PYTHONPATH=/home/ubuntu/chad_finale
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/home/ubuntu/chad_finale/venv/bin/python3 -m chad.ops.advisory_pre_market
StandardOutput=journal
StandardError=journal
SyslogIdentifier=chad-advisory-pre-market

[Install]
WantedBy=multi-user.target
