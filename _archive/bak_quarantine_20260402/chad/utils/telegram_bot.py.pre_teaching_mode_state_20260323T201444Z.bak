        return
    symbol = str(context.args[0]).strip().upper()
    try:
        payload = backend_client().ai_price(symbol)
        send_message(update, context, "<b>PRICE</b>\n\n" + escape_html(safe_json_dumps(payload, pretty=True)))
    except Exception as exc:
