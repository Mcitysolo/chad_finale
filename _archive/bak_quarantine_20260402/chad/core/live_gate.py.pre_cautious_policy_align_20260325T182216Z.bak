"""
chad/core/live_gate.py

PHASE 12+ — LiveGate (Final Authority) — Production-Grade, Fail-Closed

This module is CHAD's final allow/deny evaluator. It must be:
- deterministic
- fail-closed (unknown state => deny)
- auditable (stable reasons + bounded details)
- fast (small runtime JSON reads only)

This version adds mutation-awareness without enabling any new trading powers:
- Reads runtime/action_state.json
- Reads runtime/change_canary_state.json
- Blocks LIVE when pending/rejected mutation queues exist
- Blocks LIVE when change canary is active (< 1.0 or future expiry)
- Blocks LIVE when mutation runtime is missing/stale/invalid
- Preserves existing external API shape from to_dict()

IMPORTANT:
- LiveGate does not execute trades.
- LiveGate does not modify config.
- LiveGate only reads runtime state and emits a final decision.
"""

from __future__ import annotations

import json
import os
from dataclasses import asdict, dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Literal, Optional, Tuple

# ----------------------------
# Domain Types
# ----------------------------

LiveGateMode = Literal["DENY_ALL", "EXIT_ONLY", "ALLOW_LIVE"]


@dataclass(frozen=True)
class GateResult:
    name: str
    passed: bool
    reason: str
    details: Dict[str, Any]


@dataclass(frozen=True)
class Freshness:
    ok: bool
    reason: str
    age_s: float
    ttl_s: float


@dataclass(frozen=True)
class ExecutionConfig:
    """
    Execution posture only. Not a permission system.

    exec_mode:
      - "dry_run"
      - "paper"
      - "live"
    """
    exec_mode: str
    raw_mode_enum: str
    ibkr_enabled: bool
    ibkr_dry_run: bool
    kraken_enabled: bool


@dataclass(frozen=True)
class ModeState:
    chad_mode: str
    live_enabled: bool


@dataclass(frozen=True)
class ShadowState:
    state: str
    sizing_factor: float
    paper_only: bool
    reasons: List[str]
    stats: Dict[str, Any]


@dataclass(frozen=True)
class OperatorIntent:
    operator_mode: str
    operator_reason: str
    allow_exits_only: bool
    allow_ibkr_live: bool
    allow_ibkr_paper: bool


@dataclass(frozen=True)
class StopState:
    stop: bool
    reason: str


@dataclass(frozen=True)
class ReconciliationState:
    ok: bool
    status: str  # GREEN | RED | UNKNOWN
    reason: str
    details: Dict[str, Any]


@dataclass(frozen=True)
class LifecycleTruthState:
    ok: bool
    truth_ok: bool
    gap_flag: bool
    backlog_flag: bool
    reason: str
    details: Dict[str, Any]


@dataclass(frozen=True)
class MutationState:
    ok: bool
    pending_count: int
    approved_count: int
    rejected_count: int
    last_apply_ts_utc: Optional[str]
    lockout_until_ts_utc: Optional[str]
    reason: str
    details: Dict[str, Any]


@dataclass(frozen=True)
class CanaryState:
    ok: bool
    canary_factor: float
    canary_until_ts_utc: Optional[str]
    last_action_id: Optional[str]
    reason: str
    details: Dict[str, Any]


@dataclass(frozen=True)
class LiveReadinessState:
    ok: bool
    ready_for_live: bool
    reason: str
    details: Dict[str, Any]


@dataclass(frozen=True)
class ExecutionQualityState:
    ok: bool
    env_label: str
    reason: str
    details: Dict[str, Any]


@dataclass(frozen=True)
class LiveGateContext:
    execution: ExecutionConfig
    mode: ModeState
    shadow: ShadowState
    operator_intent: OperatorIntent
    stop_state: StopState
    live_readiness: LiveReadinessState
    execution_quality: ExecutionQualityState
    reconciliation: ReconciliationState
    lifecycle_truth: LifecycleTruthState
    mutation_state: MutationState
    canary_state: CanaryState


@dataclass(frozen=True)
class LiveGateDecision:
    context: LiveGateContext
    mode: LiveGateMode
    reasons: List[str]
    allow_exits_only: bool
    allow_ibkr_live: bool
    allow_ibkr_paper: bool

    def to_dict(self) -> Dict[str, Any]:
        # Preserve existing external response shape.
        return {
            "execution": asdict(self.context.execution),
            "mode": asdict(self.context.mode),
            "shadow": asdict(self.context.shadow),
            "operator_mode": self.context.operator_intent.operator_mode,
            "operator_reason": self.context.operator_intent.operator_reason,
            "allow_exits_only": bool(self.allow_exits_only),
            "allow_ibkr_live": bool(self.allow_ibkr_live),
            "allow_ibkr_paper": bool(self.allow_ibkr_paper),
            "reasons": list(self.reasons),
        }


# ----------------------------
# Runtime Path Resolution
# ----------------------------

def _repo_root() -> Path:
    """
    Resolve CHAD repo root robustly:
    1) CHAD_ROOT env
    2) walk up from this file until ./chad and ./runtime exist
    3) known deployment fallback
    4) cwd last resort
    """
    env = (os.environ.get("CHAD_ROOT") or "").strip()
    if env:
        p = Path(env).expanduser().resolve()
        if (p / "chad").is_dir() and (p / "runtime").is_dir():
            return p

    here = Path(__file__).resolve()
    for parent in [here.parent, *here.parents]:
        if (parent / "chad").is_dir() and (parent / "runtime").is_dir():
            return parent

    for candidate in (Path("/home/ubuntu/chad_finale"),):
        if (candidate / "chad").is_dir() and (candidate / "runtime").is_dir():
            return candidate

    return Path.cwd().resolve()


def _runtime_dir() -> Path:
    return (_repo_root() / "runtime").resolve()


# ----------------------------
# Runtime JSON Reader (Fail-Closed)
# ----------------------------

def _parse_utc_iso(s: str) -> datetime:
    ss = (s or "").strip()
    if not ss:
        raise ValueError("empty_ts")
    if ss.endswith("Z"):
        ss = ss[:-1] + "+00:00"
    dt = datetime.fromisoformat(ss)
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt.astimezone(timezone.utc)


def _freshness_from_obj(obj: Dict[str, Any], *, default_ttl_s: int) -> Freshness:
    ttl_raw = obj.get("ttl_seconds", default_ttl_s)
    try:
        ttl_s = int(ttl_raw)
    except Exception:
        ttl_s = int(default_ttl_s)

    if ttl_s <= 0:
        ttl_s = int(default_ttl_s)

    ts_raw = obj.get("ts_utc")
    try:
        ts_dt = _parse_utc_iso(str(ts_raw))
    except Exception as exc:
        return Freshness(
            ok=False,
            reason=f"missing_or_bad_ts:{type(exc).__name__}",
            age_s=1_000_000_000.0,
            ttl_s=float(ttl_s),
        )

    age_s = (datetime.now(timezone.utc) - ts_dt).total_seconds()
    if age_s < 0:
        return Freshness(ok=False, reason="clock_skew", age_s=float(age_s), ttl_s=float(ttl_s))

    ok = age_s <= float(ttl_s)
    return Freshness(ok=ok, reason=("ok" if ok else "stale"), age_s=float(age_s), ttl_s=float(ttl_s))


def _read_json_file(path: Path) -> Tuple[Optional[Dict[str, Any]], str]:
    try:
        raw = path.read_text(encoding="utf-8", errors="strict")
    except FileNotFoundError:
        return None, "missing"
    except Exception as exc:
        return None, f"read_failed:{type(exc).__name__}"

    try:
        obj = json.loads(raw)
    except Exception as exc:
        return None, f"json_parse_failed:{type(exc).__name__}"

    if not isinstance(obj, dict):
        return None, "json_not_object"

    return obj, "ok"


def read_runtime_state_json(path: Path, *, default_ttl_s: int) -> Tuple[Optional[Dict[str, Any]], Freshness]:
    obj, reason = _read_json_file(path)
    if obj is None:
        return None, Freshness(ok=False, reason=reason, age_s=1_000_000_000.0, ttl_s=float(default_ttl_s))

    fr = _freshness_from_obj(obj, default_ttl_s=default_ttl_s)
    if not fr.ok:
        return None, Freshness(
            ok=False,
            reason=f"stale_or_invalid:{fr.reason}",
            age_s=fr.age_s,
            ttl_s=fr.ttl_s,
        )

    return obj, fr


def _env_bool(key: str, default: bool) -> bool:
    v = os.environ.get(key)
    if v is None:
        return bool(default)
    s = str(v).strip().lower()
    if s in ("1", "true", "yes", "y", "on"):
        return True
    if s in ("0", "false", "no", "n", "off"):
        return False
    return bool(default)


def _safe_int(v: Any, default: int = 0) -> int:
    try:
        return int(v)
    except Exception:
        return int(default)


def _safe_float(v: Any, default: float = 0.0) -> float:
    try:
        return float(v)
    except Exception:
        return float(default)


# ----------------------------
# Loaders (Fail-Closed)
# ----------------------------

def _load_stop_state() -> StopState:
    p = _runtime_dir() / "stop_state.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=24 * 60 * 60)
    if obj is None:
        return StopState(stop=True, reason=f"stop_state_{fr.reason}")

    stop = bool(obj.get("stop", True))
    reason = str(obj.get("reason") or "unspecified").strip()
    return StopState(stop=stop, reason=reason)


def _load_operator_intent() -> OperatorIntent:
    p = _runtime_dir() / "operator_intent.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=2 * 60 * 60)
    if obj is None:
        return OperatorIntent(
            operator_mode="DENY_ALL",
            operator_reason=f"operator_intent_{fr.reason}",
            allow_exits_only=False,
            allow_ibkr_live=False,
            allow_ibkr_paper=True,
        )

    mode = str(obj.get("operator_mode") or obj.get("mode") or "DENY_ALL").strip().upper()
    reason = str(obj.get("operator_reason") or obj.get("reason") or "ok").strip()

    # Back-compat normalization:
    # legacy writer may emit ALLOW instead of ALLOW_LIVE.
    if mode == "ALLOW":
        mode = "ALLOW_LIVE"

    allow_exits_only = bool(obj.get("allow_exits_only", False))
    allow_ibkr_live = bool(obj.get("allow_ibkr_live", False))
    allow_ibkr_paper = bool(obj.get("allow_ibkr_paper", True))

    if mode not in ("DENY_ALL", "EXIT_ONLY", "ALLOW_LIVE"):
        mode = "DENY_ALL"
        reason = f"operator_intent_unknown_mode:{obj.get('operator_mode')!r}"

    return OperatorIntent(
        operator_mode=mode,
        operator_reason=reason,
        allow_exits_only=allow_exits_only,
        allow_ibkr_live=allow_ibkr_live,
        allow_ibkr_paper=allow_ibkr_paper,
    )


def _load_shadow_state() -> ShadowState:
    p = _runtime_dir() / "scr_state.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=600)
    if obj is None:
        return ShadowState(
            state="PAUSED",
            sizing_factor=0.0,
            paper_only=True,
            reasons=[f"scr_state_{fr.reason}"],
            stats={},
        )

    state = str(obj.get("state") or "PAUSED").strip().upper()
    sizing = _safe_float(obj.get("sizing_factor"), 0.0)
    paper_only = bool(obj.get("paper_only", True))
    reasons = obj.get("reasons") if isinstance(obj.get("reasons"), list) else []
    stats = obj.get("stats") if isinstance(obj.get("stats"), dict) else {}

    return ShadowState(
        state=state,
        sizing_factor=float(max(0.0, min(1.0, sizing))),
        paper_only=bool(paper_only),
        reasons=[str(x) for x in reasons][:50],
        stats=stats,
    )


def _load_execution_config() -> ExecutionConfig:
    raw_mode = (
        os.environ.get("CHAD_EXECUTION_MODE")
        or os.environ.get("CHAD_EXEC_MODE")
        or os.environ.get("CHAD_MODE")
        or "dry_run"
    ).strip().lower()
    if raw_mode not in ("dry_run", "paper", "live"):
        raw_mode = "dry_run"

    ibkr_enabled = _env_bool("IBKR_ENABLED", True)
    ibkr_dry_run = _env_bool("IBKR_DRY_RUN", True)
    kraken_enabled = _env_bool("KRAKEN_ENABLED", True)

    p = _runtime_dir() / "live_mode.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=24 * 60 * 60)
    if obj is not None:
        m = str(obj.get("chad_mode") or obj.get("mode") or raw_mode).strip().lower()
        if m in ("dry_run", "paper", "live"):
            raw_mode = m

    return ExecutionConfig(
        exec_mode=str(raw_mode),
        raw_mode_enum=str(raw_mode),
        ibkr_enabled=bool(ibkr_enabled),
        ibkr_dry_run=bool(ibkr_dry_run),
        kraken_enabled=bool(kraken_enabled),
    )


def _load_mode_state(exec_cfg: ExecutionConfig) -> ModeState:
    live_enabled = bool(exec_cfg.exec_mode == "live")
    return ModeState(chad_mode=str(exec_cfg.exec_mode), live_enabled=live_enabled)


def _load_live_readiness_state() -> LiveReadinessState:
    p = _runtime_dir() / "live_readiness.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=600)
    if obj is None:
        return LiveReadinessState(
            ok=False,
            ready_for_live=False,
            reason=f"live_readiness_{fr.reason}",
            details={"path": str(p), "freshness": asdict(fr)},
        )

    ready = bool(obj.get("ready_for_live", False))
    return LiveReadinessState(
        ok=True,
        ready_for_live=ready,
        reason=("ok" if ready else "LIVE_READINESS_FALSE"),
        details={
            "path": str(p),
            "latest_report_path": obj.get("latest_report_path"),
            "latest_report_sha256": obj.get("latest_report_sha256"),
            "schema_version": obj.get("schema_version"),
        },
    )


def _load_execution_quality_state() -> ExecutionQualityState:
    p = _runtime_dir() / "execution_quality.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=600)
    if obj is None:
        return ExecutionQualityState(
            ok=False,
            env_label="unknown",
            reason=f"execution_quality_{fr.reason}",
            details={"path": str(p), "freshness": asdict(fr)},
        )

    env_label = str(obj.get("env_label") or "unknown").strip().lower()
    if env_label not in ("normal", "thin", "dangerous", "unknown"):
        env_label = "unknown"

    return ExecutionQualityState(
        ok=True,
        env_label=env_label,
        reason=("ok" if env_label in ("normal", "thin") else "EXECUTION_ENV_DANGEROUS"),
        details={
            "path": str(p),
            "env_label": env_label,
            "flags": obj.get("flags") if isinstance(obj.get("flags"), list) else [],
            "worst_offenders": obj.get("worst_offenders") if isinstance(obj.get("worst_offenders"), list) else [],
            "keys": sorted(list((obj.get("by_venue_symbol") or {}).keys())) if isinstance(obj.get("by_venue_symbol"), dict) else [],
        },
    )


def _load_reconciliation_state() -> ReconciliationState:
    p = _runtime_dir() / "reconciliation_state.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=300)
    if obj is None:
        return ReconciliationState(
            ok=False,
            status="UNKNOWN",
            reason=f"reconciliation_state_{fr.reason}",
            details={"path": str(p), "freshness": asdict(fr)},
        )

    st = str(obj.get("status") or "").strip().upper()
    if st not in ("GREEN", "RED"):
        return ReconciliationState(
            ok=False,
            status="UNKNOWN",
            reason="reconciliation_state_unknown_status",
            details={"path": str(p), "status": st},
        )

    details = {
        "path": str(p),
        "status": st,
        "counts": obj.get("counts") if isinstance(obj.get("counts"), dict) else None,
        "mismatches": obj.get("mismatches") if isinstance(obj.get("mismatches"), list) else None,
        "broker_source": obj.get("broker_source"),
        "chad_state_source": obj.get("chad_state_source"),
    }

    if st == "GREEN":
        return ReconciliationState(ok=True, status="GREEN", reason="ok", details=details)

    return ReconciliationState(ok=True, status="RED", reason="RECONCILIATION_RED", details=details)


def _load_lifecycle_truth_state() -> LifecycleTruthState:
    runtime = _runtime_dir()

    truth_path = runtime / "positions_truth.json"
    truth_obj, truth_fr = read_runtime_state_json(truth_path, default_ttl_s=120)
    if truth_obj is None:
        return LifecycleTruthState(
            ok=False,
            truth_ok=False,
            gap_flag=True,
            backlog_flag=True,
            reason=f"positions_truth_{truth_fr.reason}",
            details={"truth_path": str(truth_path), "truth_freshness": asdict(truth_fr)},
        )

    lifecycle_path = runtime / "trade_lifecycle_state.json"
    lifecycle_obj, lifecycle_fr = read_runtime_state_json(lifecycle_path, default_ttl_s=120)
    if lifecycle_obj is None:
        return LifecycleTruthState(
            ok=False,
            truth_ok=False,
            gap_flag=True,
            backlog_flag=True,
            reason=f"trade_lifecycle_state_{lifecycle_fr.reason}",
            details={
                "truth_path": str(truth_path),
                "lifecycle_path": str(lifecycle_path),
                "lifecycle_freshness": asdict(lifecycle_fr),
            },
        )

    truth_ok = bool(truth_obj.get("truth_ok", False))
    gap_flag = bool(lifecycle_obj.get("gap_flag", True))
    backlog_flag = bool(lifecycle_obj.get("backlog_flag", True))

    details = {
        "truth_path": str(truth_path),
        "lifecycle_path": str(lifecycle_path),
        "truth_source": truth_obj.get("truth_source"),
        "as_of_event_ts_utc": truth_obj.get("as_of_event_ts_utc"),
        "last_event_ts_utc": lifecycle_obj.get("last_event_ts_utc"),
        "truth_ok": truth_ok,
        "gap_flag": gap_flag,
        "backlog_flag": backlog_flag,
    }

    if not truth_ok:
        return LifecycleTruthState(
            ok=True,
            truth_ok=False,
            gap_flag=gap_flag,
            backlog_flag=backlog_flag,
            reason="TRUTH_NOT_PROVEN",
            details=details,
        )

    if gap_flag:
        return LifecycleTruthState(
            ok=True,
            truth_ok=True,
            gap_flag=True,
            backlog_flag=backlog_flag,
            reason="LIFECYCLE_GAP_FLAG",
            details=details,
        )

    if backlog_flag:
        return LifecycleTruthState(
            ok=True,
            truth_ok=True,
            gap_flag=gap_flag,
            backlog_flag=True,
            reason="LIFECYCLE_BACKLOG_FLAG",
            details=details,
        )

    return LifecycleTruthState(
        ok=True,
        truth_ok=True,
        gap_flag=False,
        backlog_flag=False,
        reason="ok",
        details=details,
    )


def _load_mutation_state() -> MutationState:
    p = _runtime_dir() / "action_state.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=120)
    if obj is None:
        return MutationState(
            ok=False,
            pending_count=0,
            approved_count=0,
            rejected_count=0,
            last_apply_ts_utc=None,
            lockout_until_ts_utc=None,
            reason=f"action_state_{fr.reason}",
            details={"path": str(p), "freshness": asdict(fr)},
        )

    return MutationState(
        ok=bool(obj.get("ok", True)),
        pending_count=max(0, _safe_int(obj.get("pending_count"), 0)),
        approved_count=max(0, _safe_int(obj.get("approved_count"), 0)),
        rejected_count=max(0, _safe_int(obj.get("rejected_count"), 0)),
        last_apply_ts_utc=(str(obj.get("last_apply_ts_utc")).strip() if obj.get("last_apply_ts_utc") else None),
        lockout_until_ts_utc=(str(obj.get("lockout_until_ts_utc")).strip() if obj.get("lockout_until_ts_utc") else None),
        reason="ok",
        details={
            "path": str(p),
            "paths": obj.get("paths") if isinstance(obj.get("paths"), dict) else {},
            "debug": obj.get("debug") if isinstance(obj.get("debug"), dict) else {},
        },
    )


def _load_canary_state() -> CanaryState:
    p = _runtime_dir() / "change_canary_state.json"
    obj, fr = read_runtime_state_json(p, default_ttl_s=120)
    if obj is None:
        return CanaryState(
            ok=False,
            canary_factor=1.0,
            canary_until_ts_utc=None,
            last_action_id=None,
            reason=f"change_canary_state_{fr.reason}",
            details={"path": str(p), "freshness": asdict(fr)},
        )

    factor = _safe_float(obj.get("canary_factor"), 1.0)
    factor = min(max(factor, 0.0), 1.0)

    return CanaryState(
        ok=True,
        canary_factor=factor,
        canary_until_ts_utc=(str(obj.get("canary_until_ts_utc")).strip() if obj.get("canary_until_ts_utc") else None),
        last_action_id=(str(obj.get("last_action_id")).strip() if obj.get("last_action_id") else None),
        reason="ok",
        details={
            "path": str(p),
            "reason": obj.get("reason"),
            "paths": obj.get("paths") if isinstance(obj.get("paths"), dict) else {},
        },
    )


# ----------------------------
# Mutation / Canary helpers
# ----------------------------

def _is_future_ts(ts_utc: Optional[str]) -> bool:
    if not ts_utc:
        return False
    try:
        dt = _parse_utc_iso(ts_utc)
    except Exception:
        return False
    return dt > datetime.now(timezone.utc)


# ----------------------------
# LiveGate Evaluation (Deterministic)
# ----------------------------

def evaluate_live_gate() -> LiveGateDecision:
    """
    Deterministic gate order:

    0) ExecutionConfig / Mode snapshot (not permission)
    1) STOP gate
    2) Operator intent gate
    3) Live readiness gate
    4) Execution quality gate
    5) SCR / shadow gate
    6) Mutation state gate
    7) Change canary gate
    8) Reconciliation gate
    9) Lifecycle truth gate
    10) Execution mode gate
    11) Final allow/deny

    All unknown runtime state fails closed.
    """
    gates: List[GateResult] = []
    reasons: List[str] = []

    exec_cfg = _load_execution_config()
    mode_state = _load_mode_state(exec_cfg)
    shadow = _load_shadow_state()
    operator = _load_operator_intent()
    stop_state = _load_stop_state()
    live_readiness = _load_live_readiness_state()
    execution_quality = _load_execution_quality_state()
    recon = _load_reconciliation_state()
    lifecycle = _load_lifecycle_truth_state()
    mutation = _load_mutation_state()
    canary = _load_canary_state()

    # Default permissions (fail-closed)
    allow_exits_only = False
    allow_ibkr_live = False
    allow_ibkr_paper = bool(exec_cfg.ibkr_enabled and exec_cfg.ibkr_dry_run)

    # Gate 1: STOP
    if stop_state.stop:
        gates.append(GateResult(name="STOP", passed=False, reason="STOP_ENGAGED", details={"reason": stop_state.reason}))
        reasons.append(f"STOP is ENABLED (DENY_ALL). reason={stop_state.reason!r}.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(GateResult(name="STOP", passed=True, reason="not_engaged", details={}))

    # Gate 2: Operator intent
    if operator.operator_mode != "ALLOW_LIVE":
        gates.append(
            GateResult(
                name="OPERATOR_INTENT",
                passed=False,
                reason="OPERATOR_INTENT_NOT_ALLOW_LIVE",
                details={"operator_mode": operator.operator_mode, "operator_reason": operator.operator_reason},
            )
        )
        reasons.append(f"OperatorIntent={operator.operator_mode} reason={operator.operator_reason!r}. Deny all lanes.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(GateResult(name="OPERATOR_INTENT", passed=True, reason="ALLOW_LIVE", details={"operator_reason": operator.operator_reason}))

    # Gate 3: Live readiness
    if not live_readiness.ok:
        gates.append(GateResult(name="LIVE_READINESS", passed=False, reason="LIVE_READINESS_UNAVAILABLE", details=live_readiness.details))
        reasons.append(f"LIVE_READINESS_UNAVAILABLE: {live_readiness.reason}. Fail-closed for LIVE execution.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if not live_readiness.ready_for_live:
        gates.append(GateResult(name="LIVE_READINESS", passed=False, reason="LIVE_READINESS_FALSE", details=live_readiness.details))
        reasons.append("LIVE_READINESS_FALSE: readiness publisher does not consider the system ready for live trading.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(GateResult(name="LIVE_READINESS", passed=True, reason="ok", details=live_readiness.details))

    # Gate 4: Execution quality
    if not execution_quality.ok:
        gates.append(GateResult(name="EXECUTION_QUALITY", passed=False, reason="EXECUTION_QUALITY_UNAVAILABLE", details=execution_quality.details))
        reasons.append(f"EXECUTION_QUALITY_UNAVAILABLE: {execution_quality.reason}. Fail-closed for LIVE execution.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if execution_quality.env_label == "dangerous":
        gates.append(GateResult(name="EXECUTION_QUALITY", passed=False, reason="EXECUTION_ENV_DANGEROUS", details=execution_quality.details))
        reasons.append("EXECUTION_ENV_DANGEROUS: broker execution environment is classified as dangerous.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if execution_quality.env_label == "unknown":
        gates.append(GateResult(name="EXECUTION_QUALITY", passed=False, reason="EXECUTION_ENV_UNKNOWN", details=execution_quality.details))
        reasons.append("EXECUTION_ENV_UNKNOWN: execution environment is not proven. Fail-closed for LIVE execution.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(GateResult(name="EXECUTION_QUALITY", passed=True, reason=execution_quality.env_label, details=execution_quality.details))

    # Gate 5: SCR
    if shadow.paper_only or shadow.state.upper() in ("PAUSED", "CAUTIOUS"):
        gates.append(
            GateResult(
                name="SCR",
                passed=False,
                reason="SCR_PAPER_ONLY",
                details={
                    "state": shadow.state,
                    "paper_only": shadow.paper_only,
                    "sizing_factor": shadow.sizing_factor,
                    "reasons": shadow.reasons[:10],
                },
            )
        )
        reasons.append("SCR_PAPER_ONLY: shadow state indicates paper_only/paused/cautious. Block LIVE.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(GateResult(name="SCR", passed=True, reason="ok", details={"state": shadow.state, "sizing_factor": shadow.sizing_factor}))

    # Gate 4: Mutation state
    if not mutation.ok:
        gates.append(GateResult(name="MUTATION_STATE", passed=False, reason="MUTATION_STATE_UNAVAILABLE", details=mutation.details))
        reasons.append(f"MUTATION_STATE_UNAVAILABLE: {mutation.reason}. Fail-closed for LIVE execution.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if mutation.pending_count > 0:
        gates.append(
            GateResult(
                name="MUTATION_STATE",
                passed=False,
                reason="PENDING_ACTIONS_UNAPPLIED",
                details={"pending_count": mutation.pending_count, "debug": mutation.details.get("debug")},
            )
        )
        reasons.append(f"PENDING_ACTIONS_UNAPPLIED: pending_count={mutation.pending_count}. Block LIVE until queue is cleared.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if mutation.rejected_count > 0:
        gates.append(
            GateResult(
                name="MUTATION_STATE",
                passed=False,
                reason="UNAPPROVED_MUTATION_DETECTED",
                details={"rejected_count": mutation.rejected_count, "debug": mutation.details.get("debug")},
            )
        )
        reasons.append(f"UNAPPROVED_MUTATION_DETECTED: rejected_count={mutation.rejected_count}. Block LIVE until investigated.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if mutation.lockout_until_ts_utc and _is_future_ts(mutation.lockout_until_ts_utc):
        gates.append(
            GateResult(
                name="MUTATION_STATE",
                passed=False,
                reason="ACTION_APPLIER_LOCKOUT_ACTIVE",
                details={"lockout_until_ts_utc": mutation.lockout_until_ts_utc},
            )
        )
        reasons.append(f"ACTION_APPLIER_LOCKOUT_ACTIVE until {mutation.lockout_until_ts_utc}. Block LIVE.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(
        GateResult(
            name="MUTATION_STATE",
            passed=True,
            reason="ok",
            details={
                "pending_count": mutation.pending_count,
                "approved_count": mutation.approved_count,
                "rejected_count": mutation.rejected_count,
            },
        )
    )

    # Gate 5: Canary
    if not canary.ok:
        gates.append(GateResult(name="CHANGE_CANARY", passed=False, reason="CHANGE_CANARY_UNAVAILABLE", details=canary.details))
        reasons.append(f"CHANGE_CANARY_UNAVAILABLE: {canary.reason}. Fail-closed for LIVE execution.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if canary.canary_factor < 1.0:
        gates.append(
            GateResult(
                name="CHANGE_CANARY",
                passed=False,
                reason="CHANGE_CANARY_ACTIVE",
                details={
                    "canary_factor": canary.canary_factor,
                    "canary_until_ts_utc": canary.canary_until_ts_utc,
                    "last_action_id": canary.last_action_id,
                },
            )
        )
        reasons.append(f"CHANGE_CANARY_ACTIVE: canary_factor={canary.canary_factor:.4f}. Block LIVE while canary is active.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if canary.canary_until_ts_utc and _is_future_ts(canary.canary_until_ts_utc):
        gates.append(
            GateResult(
                name="CHANGE_CANARY",
                passed=False,
                reason="CHANGE_CANARY_ACTIVE",
                details={
                    "canary_factor": canary.canary_factor,
                    "canary_until_ts_utc": canary.canary_until_ts_utc,
                    "last_action_id": canary.last_action_id,
                },
            )
        )
        reasons.append(f"CHANGE_CANARY_ACTIVE until {canary.canary_until_ts_utc}. Block LIVE.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(
        GateResult(
            name="CHANGE_CANARY",
            passed=True,
            reason="ok",
            details={
                "canary_factor": canary.canary_factor,
                "last_action_id": canary.last_action_id,
            },
        )
    )

    # Gate 6: Reconciliation
    if not recon.ok:
        gates.append(GateResult(name="RECONCILIATION", passed=False, reason=recon.reason, details=recon.details))
        reasons.append(f"RECONCILIATION gate failed: {recon.reason}. Fail-closed for LIVE execution.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if recon.status != "GREEN":
        gates.append(GateResult(name="RECONCILIATION", passed=False, reason="RECONCILIATION_RED", details=recon.details))
        reasons.append("RECONCILIATION_RED: broker vs ledger mismatch beyond tolerance. Block LIVE.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(GateResult(name="RECONCILIATION", passed=True, reason="GREEN", details=recon.details))

    # Gate 7: Lifecycle truth
    if not lifecycle.ok:
        gates.append(GateResult(name="LIFECYCLE_TRUTH", passed=False, reason=lifecycle.reason, details=lifecycle.details))
        reasons.append(f"LIFECYCLE_TRUTH unavailable: {lifecycle.reason}. Fail-closed for LIVE execution.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if not lifecycle.truth_ok:
        gates.append(GateResult(name="LIFECYCLE_TRUTH", passed=False, reason="TRUTH_NOT_PROVEN", details=lifecycle.details))
        reasons.append("LIFECYCLE_TRUTH not proven. Block LIVE until deterministic truth rebuild is available.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if lifecycle.gap_flag:
        gates.append(GateResult(name="LIFECYCLE_TRUTH", passed=False, reason="LIFECYCLE_GAP_FLAG", details=lifecycle.details))
        reasons.append("LIFECYCLE_GAP_FLAG is true. Block LIVE.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    if lifecycle.backlog_flag:
        gates.append(GateResult(name="LIFECYCLE_TRUTH", passed=False, reason="LIFECYCLE_BACKLOG_FLAG", details=lifecycle.details))
        reasons.append("LIFECYCLE_BACKLOG_FLAG is true. Block LIVE.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(GateResult(name="LIFECYCLE_TRUTH", passed=True, reason="ok", details=lifecycle.details))

    # Gate 8: Execution posture
    if exec_cfg.exec_mode != "live":
        gates.append(GateResult(name="EXEC_MODE", passed=False, reason="MODE_NOT_LIVE", details={"exec_mode": exec_cfg.exec_mode}))
        reasons.append(f"Execution mode is {exec_cfg.exec_mode!r}, not 'live'. Deny LIVE.")
        ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
        return LiveGateDecision(ctx, "DENY_ALL", reasons, False, False, allow_ibkr_paper)

    gates.append(GateResult(name="EXEC_MODE", passed=True, reason="live", details={}))

    # Final allow
    allow_ibkr_live = bool(exec_cfg.ibkr_enabled and not exec_cfg.ibkr_dry_run and operator.allow_ibkr_live)
    allow_exits_only = bool(operator.allow_exits_only)

    mode: LiveGateMode = "ALLOW_LIVE" if allow_ibkr_live else ("EXIT_ONLY" if allow_exits_only else "DENY_ALL")

    if mode == "ALLOW_LIVE":
        reasons.append("All gates GREEN. ALLOW_LIVE.")
    elif mode == "EXIT_ONLY":
        reasons.append("LIVE blocked, but EXIT_ONLY allowed by operator.")
    else:
        reasons.append("LIVE denied by final allow flags (ibkr_enabled/ibkr_dry_run/operator flags).")

    ctx = LiveGateContext(exec_cfg, mode_state, shadow, operator, stop_state, live_readiness, execution_quality, recon, lifecycle, mutation, canary)
    return LiveGateDecision(ctx, mode, reasons, allow_exits_only, allow_ibkr_live, allow_ibkr_paper)


# ----------------------------
# CLI
# ----------------------------

def main(argv: Optional[List[str]] = None) -> int:
    _ = argv
    d = evaluate_live_gate()
    print(json.dumps(d.to_dict(), indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
