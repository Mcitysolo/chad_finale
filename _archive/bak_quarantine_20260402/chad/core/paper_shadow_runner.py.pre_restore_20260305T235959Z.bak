#!/usr/bin/env python3
"""
CHAD — Calendar State Publisher (IBKR Trading/Liquid Hours Cache)
Production-grade, SSOT-runtime compliant.

Outputs:
  runtime/calendar_state.json
  - ALWAYS includes: ts_utc, ttl_seconds (int)
  - Atomic writes via chad.utils.runtime_json.write_runtime_state_json

Purpose:
  Provide a TTL'd "market calendar / session open" cache that higher layers can read without
  making broker calls. This publisher is the only component responsible for maintaining the
  runtime/calendar_state.json contract.

Key features:
  - Strategy-based symbol discovery (positions_snapshot, universe.json, env allowlist)
  - Per-key caching with fetched_ts_utc and per-key TTL (cache_ttl_s)
  - Robust IBKR connection + contractDetails retries with exponential backoff + jitter
  - Safe fail-closed semantics: cache is written even when IBKR is down, with staleness evidence
  - Deterministic output shape, stable timestamps, no secrets in logs

Environment:
  CHAD_ROOT=/home/ubuntu/chad_finale (preferred)
  CHAD_RUNTIME_DIR=/home/ubuntu/chad_finale/runtime (optional)
  CHAD_CALENDAR_STATE_TTL_SECONDS=600       # runtime file TTL (default 600)
  CHAD_CONTRACT_CACHE_TTL_SECONDS=1800      # per-symbol cached hours TTL (default 1800)
  CHAD_CALENDAR_MAX_SYMBOLS=50              # cap per run (default 50)
  CHAD_CALENDAR_SYMBOLS="AAPL,MSFT,SPY"     # optional override allowlist
  CHAD_USE_POSITIONS_FOR_CALENDAR=1         # default true
  CHAD_USE_UNIVERSE_FOR_CALENDAR=1          # default true
  IBKR_HOST=127.0.0.1                       # default
  IBKR_PORT=4002                            # default (paper gateway common)
  IBKR_CLIENT_ID=117                        # default (choose non-conflicting)
  CHAD_IBKR_DETAILS_RETRIES=2               # default 2
  CHAD_IBKR_CONNECT_RETRIES=2               # default 2

CLI:
  --once (default)
  --loop --interval-seconds 600
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import random
import time
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Iterable, List, Optional, Protocol, Tuple

from chad.utils.runtime_json import read_runtime_state_json, write_runtime_state_json

LOG = logging.getLogger("chad.ops.calendar_state_publisher")


# ----------------------------
# Utilities
# ----------------------------

def utc_now() -> datetime:
    return datetime.now(timezone.utc)

def iso_utc(dt: Optional[datetime] = None) -> str:
    d = dt or utc_now()
    return d.strftime("%Y-%m-%dT%H:%M:%S.%fZ")

def env_str(name: str, default: str = "") -> str:
    return str(os.environ.get(name, default)).strip()

def env_int(name: str, default: int) -> int:
    raw = str(os.environ.get(name, "")).strip()
    try:
        v = int(raw)
        return v if v > 0 else default
    except Exception:
        return default

def env_bool(name: str, default: bool = False) -> bool:
    raw = str(os.environ.get(name, "")).strip().lower()
    if raw in {"1", "true", "yes", "y", "on"}:
        return True
    if raw in {"0", "false", "no", "n", "off"}:
        return False
    return default

def jitter_sleep(base_s: float, *, jitter_frac: float = 0.25) -> None:
    j = base_s * jitter_frac
    time.sleep(max(0.05, base_s + random.uniform(-j, j)))

def repo_root() -> Path:
    root = env_str("CHAD_ROOT", "")
    if root:
        p = Path(root).expanduser()
        if p.is_dir():
            return p.resolve()
    # chad/ops -> chad -> repo
    return Path(__file__).resolve().parents[2]

def runtime_dir(root: Path) -> Path:
    rd = env_str("CHAD_RUNTIME_DIR", "")
    if rd:
        return Path(rd).expanduser().resolve()
    return (root / "runtime").resolve()

def parse_csv_symbols(s: str) -> List[str]:
    out: List[str] = []
    for p in (s or "").split(","):
        x = p.strip().upper()
        if x:
            out.append(x)
    # stable de-dup
    seen = set()
    dedup: List[str] = []
    for x in out:
        if x not in seen:
            seen.add(x)
            dedup.append(x)
    return dedup


# ----------------------------
# Config
# ----------------------------

@dataclass(frozen=True)
class IbkrConfig:
    host: str
    port: int
    client_id: int
    connect_retries: int
    details_retries: int

@dataclass(frozen=True)
class CalendarConfig:
    runtime_path: Path
    runtime_ttl_s: int
    per_symbol_cache_ttl_s: int
    max_symbols: int
    symbols_override: List[str]
    use_positions: bool
    use_universe: bool


# ----------------------------
# Symbol sources (Strategy pattern)
# ----------------------------

class SymbolSource(Protocol):
    def symbols(self) -> List[str]: ...

class PositionsSnapshotSource:
    def __init__(self, rt: Path) -> None:
        self._path = rt / "positions_snapshot.json"

    def symbols(self) -> List[str]:
        if not self._path.is_file():
            return []
        try:
            obj, _ = read_runtime_state_json(self._path, default_ttl_seconds=0)
        except Exception:
            return []
        pos = obj.get("positions")
        if not isinstance(pos, list):
            return []
        out: List[str] = []
        for it in pos:
            if not isinstance(it, dict):
                continue
            s = it.get("symbol")
            if isinstance(s, str) and s.strip():
                out.append(s.strip().upper())
        return out

class UniverseFileSource:
    def __init__(self, rt: Path) -> None:
        self._path = rt / "universe.json"

    def symbols(self) -> List[str]:
        if not self._path.is_file():
            return []
        try:
            obj = json.loads(self._path.read_text(encoding="utf-8"))
        except Exception:
            return []
        # Accept {"symbols":[...]} or list
        if isinstance(obj, dict) and isinstance(obj.get("symbols"), list):
            raw = obj["symbols"]
        elif isinstance(obj, list):
            raw = obj
        else:
            return []
        out: List[str] = []
        for x in raw:
            s = str(x).strip().upper()
            if s:
                out.append(s)
        return out


# ----------------------------
# IBKR adapter (Facade + bounded retries)
# ----------------------------

class IbkrClient:
    """
    Small facade around ib_insync IB + contractDetails.

    - Connect with retries
    - Fetch contract hours with retries
    - Always disconnect cleanly
    """

    def __init__(self, cfg: IbkrConfig) -> None:
        self._cfg = cfg
        self._ib = None

    def connect(self) -> None:
        from ib_insync import IB  # type: ignore

        last: Optional[Exception] = None
        for attempt in range(self._cfg.connect_retries + 1):
            ib = IB()
            try:
                ib.connect(self._cfg.host, int(self._cfg.port), clientId=int(self._cfg.client_id), timeout=10)
                if not ib.isConnected():
                    raise RuntimeError("ibkr_connected_false")
                self._ib = ib
                return
            except Exception as e:
                last = e
                try:
                    ib.disconnect()
                except Exception:
                    pass
                if attempt >= self._cfg.connect_retries:
                    break
                jitter_sleep(0.6 * (2 ** attempt), jitter_frac=0.25)
        raise RuntimeError(f"ibkr_connect_failed: {last!r}")

    def disconnect(self) -> None:
        try:
            if self._ib is not None:
                self._ib.disconnect()
        except Exception:
            pass
        self._ib = None

    def fetch_contract_hours(self, *, symbol: str, exchange: str = "SMART", currency: str = "USD") -> Dict[str, str]:
        if self._ib is None:
            raise RuntimeError("ibkr_not_connected")

        from ib_insync import Stock  # type: ignore

        contract = Stock(symbol, exchange, currency)
        last: Optional[Exception] = None

        for attempt in range(self._cfg.details_retries + 1):
            try:
                details_list = self._ib.reqContractDetails(contract)
                if not details_list:
                    raise RuntimeError("contractDetails_empty")
                d = details_list[0]
                liquid = str(getattr(d, "liquidHours", "") or "")
                trading = str(getattr(d, "tradingHours", "") or "")
                return {"liquidHours": liquid, "tradingHours": trading}
            except Exception as e:
                last = e
                if attempt >= self._cfg.details_retries:
                    break
                jitter_sleep(0.6 * (2 ** attempt), jitter_frac=0.25)

        raise RuntimeError(f"contractDetails_failed[{symbol}]: {last!r}")


# ----------------------------
# Cache model + publisher
# ----------------------------

def _cache_path(rt: Path) -> Path:
    return rt / "calendar_state.json"

def _load_cache(rt: Path) -> Dict[str, Any]:
    p = _cache_path(rt)
    if not p.is_file():
        return {"items": {}, "ts_utc": "", "ttl_seconds": 0}
    try:
        obj, _ = read_runtime_state_json(p, default_ttl_seconds=0)
        return obj if isinstance(obj, dict) else {"items": {}, "ts_utc": "", "ttl_seconds": 0}
    except Exception:
        return {"items": {}, "ts_utc": "", "ttl_seconds": 0}

def _is_fresh(ts_utc_str: str, *, now: datetime, ttl_s: int) -> bool:
    if not ts_utc_str:
        return False
    try:
        dt = datetime.fromisoformat(ts_utc_str.replace("Z", "+00:00")).astimezone(timezone.utc)
        age = (now - dt).total_seconds()
        return age <= float(ttl_s)
    except Exception:
        return False


class CalendarStatePublisher:
    def __init__(self, cfg: CalendarConfig) -> None:
        self._cfg = cfg

    def publish(self, *, items: Dict[str, Any], now: datetime, notes: str) -> None:
        payload: Dict[str, Any] = {
            "items": items,
            "notes": notes,
        }
        write_runtime_state_json(
            self._cfg.runtime_path,
            payload,
            ttl_seconds=int(self._cfg.runtime_ttl_s),
            inject_ts=True,
        )


# ----------------------------
# Orchestrator
# ----------------------------

class CalendarOrchestrator:
    def __init__(
        self,
        *,
        cal_cfg: CalendarConfig,
        ibkr_cfg: IbkrConfig,
        symbol_sources: List[SymbolSource],
    ) -> None:
        self._cal_cfg = cal_cfg
        self._ibkr_cfg = ibkr_cfg
        self._sources = symbol_sources
        self._publisher = CalendarStatePublisher(
            CalendarConfig(
                runtime_path=cal_cfg.runtime_path,
                runtime_ttl_s=cal_cfg.runtime_ttl_s,
                per_symbol_cache_ttl_s=cal_cfg.per_symbol_cache_ttl_s,
                max_symbols=cal_cfg.max_symbols,
                symbols_override=cal_cfg.symbols_override,
                use_positions=cal_cfg.use_positions,
                use_universe=cal_cfg.use_universe,
            )
        )

    def _build_symbol_list(self) -> List[str]:
        # Override wins
        if self._cal_cfg.symbols_override:
            return self._cal_cfg.symbols_override[: self._cal_cfg.max_symbols]

        # Merge sources deterministically
        merged: List[str] = []
        for src in self._sources:
            merged.extend(src.symbols())

        # Stable de-dup, cap
        seen = set()
        out: List[str] = []
        for s in merged:
            x = str(s).strip().upper()
            if not x or x in seen:
                continue
            seen.add(x)
            out.append(x)
            if len(out) >= self._cal_cfg.max_symbols:
                break
        return out

    def run_once(self) -> int:
        now = utc_now()
        rt = self._cal_cfg.runtime_path.parent
        rt.mkdir(parents=True, exist_ok=True)

        cache = _load_cache(rt)
        items = cache.get("items") if isinstance(cache.get("items"), dict) else {}
        if not isinstance(items, dict):
            items = {}

        symbols = self._build_symbol_list()
        if not symbols:
            # Still publish an empty but valid runtime file (SSOT contract)
            self._publisher.publish(items={}, now=now, notes="no_symbols_found")
            return 0

        client = IbkrClient(self._ibkr_cfg)
        errors: List[str] = []
        updated = 0

        try:
            client.connect()
            for sym in symbols:
                key = f"{sym}::SMART::USD"
                existing = items.get(key) if isinstance(items.get(key), dict) else None
                fetched_ts = str(existing.get("fetched_ts_utc") or "") if isinstance(existing, dict) else ""

                # Respect per-key TTL
                if _is_fresh(fetched_ts, now=now, ttl_s=self._cal_cfg.per_symbol_cache_ttl_s):
                    continue

                try:
                    hours = client.fetch_contract_hours(symbol=sym, exchange="SMART", currency="USD")
                    items[key] = {
                        "fetched_ts_utc": iso_utc(now),
                        "liquidHours": hours.get("liquidHours", ""),
                        "tradingHours": hours.get("tradingHours", ""),
                    }
                    updated += 1
                except Exception as e:
                    errors.append(f"{sym}:{e!r}")
                    # keep old cached entry if any; fail-closed happens via staleness if everything stops updating

        except Exception as e:
            errors.append(f"ibkr_connect:{e!r}")
        finally:
            client.disconnect()

        notes = f"ok updated={updated} errors={len(errors)} symbols={len(symbols)}"
        if errors:
            # include only a small sample (avoid log bloat)
            notes += " sample_errors=" + ";".join(errors[:5])

        # publish full state (valid runtime contract with ttl)
        self._publisher.publish(items=items, now=now, notes=notes)
        return 0


# ----------------------------
# Entry
# ----------------------------

def build_configs(root: Path) -> Tuple[CalendarConfig, IbkrConfig, List[SymbolSource]]:
    rt = runtime_dir(root)
    rt.mkdir(parents=True, exist_ok=True)

    runtime_ttl_s = env_int("CHAD_CALENDAR_STATE_TTL_SECONDS", 600)
    per_symbol_ttl_s = env_int("CHAD_CONTRACT_CACHE_TTL_SECONDS", 1800)
    max_symbols = env_int("CHAD_CALENDAR_MAX_SYMBOLS", 50)

    symbols_override = parse_csv_symbols(env_str("CHAD_CALENDAR_SYMBOLS", ""))

    use_positions = env_bool("CHAD_USE_POSITIONS_FOR_CALENDAR", True)
    use_universe = env_bool("CHAD_USE_UNIVERSE_FOR_CALENDAR", True)

    cal_cfg = CalendarConfig(
        runtime_path=rt / "calendar_state.json",
        runtime_ttl_s=runtime_ttl_s,
        per_symbol_cache_ttl_s=per_symbol_ttl_s,
        max_symbols=max_symbols,
        symbols_override=symbols_override,
        use_positions=use_positions,
        use_universe=use_universe,
    )

    ibkr_cfg = IbkrConfig(
        host=env_str("IBKR_HOST", "127.0.0.1"),
        port=env_int("IBKR_PORT", 4002),
        client_id=env_int("IBKR_CLIENT_ID", 117),
        connect_retries=env_int("CHAD_IBKR_CONNECT_RETRIES", 2),
        details_retries=env_int("CHAD_IBKR_DETAILS_RETRIES", 2),
    )

    sources: List[SymbolSource] = []
    if use_positions:
        sources.append(PositionsSnapshotSource(rt))
    if use_universe:
        sources.append(UniverseFileSource(rt))

    return cal_cfg, ibkr_cfg, sources


def main() -> int:
    ap = argparse.ArgumentParser(description="Publish runtime/calendar_state.json (IBKR hours cache) SSOT-compliant.")
    ap.add_argument("--loop", action="store_true", help="Run forever")
    ap.add_argument("--interval-seconds", type=int, default=600, help="Loop interval")
    ap.add_argument("--log-level", type=str, default=env_str("CHAD_LOG_LEVEL", "INFO"))
    args = ap.parse_args()

    logging.basicConfig(
        level=getattr(logging, str(args.log_level).upper(), logging.INFO),
        format="%(asctime)sZ %(levelname)s %(name)s %(message)s",
    )

    root = repo_root()
    cal_cfg, ibkr_cfg, sources = build_configs(root)
    orch = CalendarOrchestrator(cal_cfg=cal_cfg, ibkr_cfg=ibkr_cfg, symbol_sources=sources)

    if not args.loop:
        return orch.run_once()

    interval = int(max(30, args.interval_seconds))
    LOG.info("calendar_state loop starting interval=%ss runtime=%s", interval, str(cal_cfg.runtime_path))
    while True:
        try:
            orch.run_once()
        except Exception:
            LOG.exception("calendar_state publisher error (continuing)")
        time.sleep(interval)


if __name__ == "__main__":
    raise SystemExit(main())
