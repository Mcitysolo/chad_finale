# Engine registry
# ---------------------------------------------------------------------

DEFAULT_ENGINE_SPECS: Tuple[EngineSpec, ...] = (
    EngineSpec(
        name="research_engine",
        module_name="chad.intel.research_engine",
        candidate_functions=(
            "run_research_scenario_from_request",
            "run_research_scenario",
            "run_research_engine",
            "run_research_job",
            "run_research",
            "build_research_report",
        ),
        timeout_seconds=12.0,
    ),
    EngineSpec(
        name="lessons_engine",
        module_name="chad.intel.lessons_engine",
        candidate_functions=("run_lessons_engine", "run_lessons_job", "run_lessons", "build_lessons_report"),
        timeout_seconds=8.0,
    ),
    EngineSpec(
        name="risk_explainer",
        module_name="chad.intel.risk_explainer",
        candidate_functions=(
            "build_risk_explanation",
            "render_risk_summary_text",
            "run_risk_explainer",
            "explain_risk",
            "build_risk_explainer",
            "build_risk_report",
        ),
        timeout_seconds=8.0,
    ),
    EngineSpec(
        name="macro_interpreter",
        module_name="chad.intel.macro_interpreter",
