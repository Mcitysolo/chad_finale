# ---------------------------------------------------------------------
# Advisory service
# ---------------------------------------------------------------------

class AdvisoryService:
    def __init__(
        self,
        *,
        runtime_provider: Optional[RuntimeStateProvider] = None,
        engine_runner: Optional[EngineRunner] = None,
        llm_client: Optional[LLMClient] = None,
    ) -> None:
        self._runtime_provider = runtime_provider or RuntimeStateProvider()
        self._engine_runner = engine_runner or EngineRunner(DEFAULT_ENGINE_SPECS)
        self._llm_client = llm_client or OpenAIAdvisoryClient()

    def run(self, request: AdvisoryRequest) -> AdvisoryResult:
        ts = utc_now_iso()
        runtime_state = self._runtime_provider.collect()
        engine_results = self._engine_runner.run_all(request)
        synthesis_ok, analysis_text, model_name, prompt_preview = self._llm_client.synthesize(request, runtime_state, engine_results)

        diagnostics = {
            "runtime_dir": str(runtime_dir()),
            "engine_count": len(engine_results),
            "engines_ok": sorted([name for name, r in engine_results.items() if r.ok]),
            "engines_failed": sorted([name for name, r in engine_results.items() if not r.ok]),
        }

        return AdvisoryResult(
            ts_utc=ts,
            symbol=request.symbol,
            user_question=request.user_question,
            local_runtime_state=runtime_state,
            engine_results=engine_results,
            synthesis_model=model_name,
            synthesis_ok=synthesis_ok,
            analysis_text=analysis_text,
            raw_prompt_preview=prompt_preview,
            diagnostics=diagnostics,
        )


# ---------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------


def advisory_reports_dir() -> Path:
    p = repo_root() / "reports" / "advisory"
    p.mkdir(parents=True, exist_ok=True)
    return p


def advisory_report_path(symbol: str, ts_utc: str) -> Path:
    safe_symbol = str(symbol).strip().upper() or "UNKNOWN"
    compact_ts = (
        str(ts_utc)
        .replace(":", "")
        .replace("-", "")
        .replace("+00:00", "Z")
        .replace("+0000", "Z")
    )
    compact_ts = compact_ts.replace(".", "_")
    return advisory_reports_dir() / f"ADVISORY_{safe_symbol}_{compact_ts}.json"


def persist_advisory_result(result: AdvisoryResult) -> Path:
    out_path = advisory_report_path(result.symbol, result.ts_utc)
    payload = result.to_dict()
    out_path.write_text(json.dumps(payload, indent=2, sort_keys=True, ensure_ascii=False) + "\n", encoding="utf-8")
    return out_path


def run_advisory_service(
    symbol: str,
    user_question: str,
    *,
    horizon: str = "unspecified",
    risk_profile: str = "unspecified",
    user_context: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    request = AdvisoryRequest(
        symbol=str(symbol).strip().upper(),
        user_question=str(user_question).strip(),
        horizon=str(horizon).strip(),
        risk_profile=str(risk_profile).strip(),
        user_context=dict(user_context or {}),
    )
    service = AdvisoryService()
    result = service.run(request)
    report_path = persist_advisory_result(result)
    out = result.to_dict()
    out["report_path"] = str(report_path)
    return out


def run_full_advisory(
    symbol: str,
    user_question: str,
    *,
    horizon: str = "unspecified",
    risk_profile: str = "unspecified",
    user_context: Optional[Dict[str, Any]] = None,
    as_dict: bool = True,
) -> Dict[str, Any] | AdvisoryResult:
    request = AdvisoryRequest(
        symbol=str(symbol).strip().upper(),
        user_question=str(user_question).strip(),
        horizon=str(horizon).strip(),
        risk_profile=str(risk_profile).strip(),
        user_context=dict(user_context or {}),
    )
    service = AdvisoryService()
    result = service.run(request)
    report_path = persist_advisory_result(result)

    if as_dict:
        out = result.to_dict()
        out["report_path"] = str(report_path)
        return out

    return result


# ---------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------

def parse_args(argv: Optional[Sequence[str]] = None) -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Run CHAD full advisory synthesis.")
    p.add_argument("symbol", help="Ticker/symbol, e.g. AAPL")
    p.add_argument("question", help="User question, e.g. 'Should I buy this stock right now?'")
    p.add_argument("--horizon", default="unspecified", help="Optional horizon label")
    p.add_argument("--risk-profile", default="unspecified", help="Optional risk profile label")
    p.add_argument("--pretty", action="store_true", help="Pretty-print JSON output")
    p.add_argument("--analysis-only", action="store_true", help="Print only synthesized analysis text")
    p.add_argument("--log-level", default=os.environ.get("CHAD_LOG_LEVEL", "INFO"))
    return p.parse_args(argv)


def main(argv: Optional[Sequence[str]] = None) -> int:
    args = parse_args(argv)
    logging.basicConfig(
        level=getattr(logging, str(args.log_level).upper(), logging.INFO),
        format="%(asctime)sZ %(levelname)s %(name)s %(message)s",
    )

    result = run_full_advisory(
        args.symbol,
        args.question,
        horizon=args.horizon,
        risk_profile=args.risk_profile,
        as_dict=True,
    )

    if args.analysis_only:
        print(str(result["analysis_text"]))
        return 0

    if args.pretty:
        print(json.dumps(result, indent=2, sort_keys=True, ensure_ascii=False))
    else:
        print(json.dumps(result, sort_keys=True, ensure_ascii=False))

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
