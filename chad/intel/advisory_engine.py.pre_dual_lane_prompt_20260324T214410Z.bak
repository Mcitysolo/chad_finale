#!/usr/bin/env python3
from __future__ import annotations

"""
CHAD Advisory Engine
====================

Production-grade orchestration layer for CHAD's higher-level intelligence stack.

Purpose
-------
Combine multiple "brains" into one coherent advisory answer:
    1. Research engine
    2. Lessons learned engine
    3. Risk explainer
    4. Macro interpreter
    5. Model doctor

Then synthesize the results into a user-facing explanation using OpenAI.

Key guarantees
--------------
- Fail-soft: one engine failure never kills the whole advisory run
- Deterministic structure: always returns the same top-level schema
- Parallel execution for speed
- Dynamic symbol resolution for engine function names
- Safe normalization of arbitrary engine outputs
- Runtime-state aware (positions/reconciliation/live gate/feed/SCR if available)
- CLI + importable API
"""

import argparse
import importlib
import inspect
import json
import logging
import os
import threading
import traceback
from concurrent.futures import ThreadPoolExecutor, TimeoutError as FuturesTimeoutError
from dataclasses import asdict, dataclass, field, is_dataclass
from datetime import datetime, timezone
from functools import lru_cache
from pathlib import Path
from typing import Any, Callable, Dict, Iterable, List, Mapping, MutableMapping, Optional, Protocol, Sequence, Tuple

try:
    from openai import OpenAI
except Exception:  # pragma: no cover
    OpenAI = None  # type: ignore


