def utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def repo_root() -> Path:
    env = str(os.environ.get("CHAD_ROOT", "")).strip()
    if env:
        p = Path(env).expanduser().resolve()
        if (p / "chad").is_dir():
            return p
    return Path(__file__).resolve().parents[2]


def runtime_dir() -> Path:
    raw = str(os.environ.get("CHAD_RUNTIME_DIR", "")).strip()
    if raw:
        return Path(raw).expanduser().resolve()
    return (repo_root() / "runtime").resolve()


def safe_json_dumps(obj: Any) -> str:
    return json.dumps(obj, sort_keys=True, ensure_ascii=False, indent=2)


def read_json_dict(path: Path) -> Dict[str, Any]:
    try:
        raw = path.read_text(encoding="utf-8")
        obj = json.loads(raw)
        return obj if isinstance(obj, dict) else {}
    except Exception:
        return {}


def truncate_text(text: str, max_chars: int) -> str:
    if len(text) <= max_chars:
        return text
    return text[: max(0, max_chars - 3)] + "..."


def _load_live_fx_usdcad() -> Optional[Dict[str, Any]]:
    import requests
    from datetime import datetime, timedelta, timezone

    api_key = str(os.environ.get("POLYGON_API_KEY", "")).strip()
    if not api_key:
        env_path = Path("/etc/chad/polygon.env")
        if env_path.is_file():
            try:
                for raw in env_path.read_text(encoding="utf-8", errors="ignore").splitlines():
                    line = raw.strip()
                    if not line or line.startswith("#") or "=" not in line:
                        continue
                    k, v = line.split("=", 1)
                    if k.strip() == "POLYGON_API_KEY" and v.strip():
                        api_key = v.strip().strip('"').strip("'")
                        break
            except Exception:
                api_key = api_key

    if not api_key:
        return None

    try:
        end = datetime.now(timezone.utc)
        start = end - timedelta(days=2)
        url = (
            f"https://api.polygon.io/v2/aggs/ticker/C:USDCAD/range/1/minute/"
            f"{start.strftime('%Y-%m-%d')}/{end.strftime('%Y-%m-%d')}"
        )
        resp = requests.get(
            url,
            params={
                "adjusted": "true",
                "sort": "desc",
                "limit": 1,
                "apiKey": api_key,
            },
            timeout=15,
        )
        if resp.status_code != 200:
            return None

        payload = resp.json()
        results = payload.get("results")
        if not isinstance(results, list) or not results:
            return None

        row = results[0]
        if not isinstance(row, dict):
            return None

        close_px = row.get("c")
        ts_ms = row.get("t")
        status = str(payload.get("status") or "").strip()

        if not isinstance(close_px, (int, float)):
            return None

        ts_utc = None
        if isinstance(ts_ms, (int, float)):
            try:
                ts_utc = datetime.fromtimestamp(float(ts_ms) / 1000.0, tz=timezone.utc).isoformat().replace("+00:00", "Z")
            except Exception:
                ts_utc = None

        return {
            "pair": "C:USDCAD",
            "rate": float(close_px),
            "ts_utc": ts_utc,
            "status": status,
            "source": "polygon_aggs_delayed",
        }
    except Exception:
        return None


def _load_live_context(symbol: str) -> Dict[str, Any]:
    runtime = runtime_dir()
    symbol = str(symbol or "").strip().upper()

    price_usd = None
    price_cad = None
    fx_usdcad = None
    fx_meta = None
    position = None
    portfolio_value_usd = None
    position_value_usd = None
    position_weight_pct = None
    position_balance_label = "none"

    try:
        price_cache = read_json_dict(runtime / "price_cache.json")
        prices = price_cache.get("prices")
        if isinstance(prices, dict):
            raw_px = prices.get(symbol)
            if isinstance(raw_px, (int, float)):
                price_usd = float(raw_px)
    except Exception:
        pass

    fx_meta = _load_live_fx_usdcad()
    if isinstance(fx_meta, dict):
        raw_rate = fx_meta.get("rate")
        if isinstance(raw_rate, (int, float)):
            fx_usdcad = float(raw_rate)

    if isinstance(price_usd, (int, float)) and isinstance(fx_usdcad, (int, float)):
        price_cad = round(float(price_usd) * float(fx_usdcad), 2)

    try:
        snap = read_json_dict(runtime / "positions_snapshot.json")
        positions = snap.get("positions")
        if isinstance(positions, list):
            for row in positions:
                if not isinstance(row, dict):
                    continue
                if str(row.get("symbol") or "").strip().upper() != symbol:
                    continue
                position = {
                    "qty": float(row.get("position") or 0.0),
                    "avg_cost_usd": float(row.get("avgCost") or 0.0),
                    "currency": str(row.get("currency") or "USD").strip().upper(),
                }
                break
    except Exception:
        pass

    try:
        portfolio = read_json_dict(runtime / "portfolio_snapshot.json")
        raw_equity = portfolio.get("ibkr_equity")
        if isinstance(raw_equity, (int, float)):
            portfolio_value_usd = float(raw_equity)
    except Exception:
        pass

    if isinstance(position, dict):
        qty = position.get("qty")
        if isinstance(qty, (int, float)):
            qty = float(qty)
            if isinstance(price_usd, (int, float)):
                position_value_usd = abs(qty * float(price_usd))
            elif isinstance(position.get("avg_cost_usd"), (int, float)):
                position_value_usd = abs(qty * float(position["avg_cost_usd"]))

    if isinstance(position_value_usd, (int, float)) and isinstance(portfolio_value_usd, (int, float)) and portfolio_value_usd > 0:
        position_weight_pct = round((float(position_value_usd) / float(portfolio_value_usd)) * 100.0, 2)

    if not isinstance(position, dict):
        position_balance_label = "none"
    elif isinstance(position_weight_pct, (int, float)):
        w = float(position_weight_pct)
        if w < 2.0:
            position_balance_label = "small"
        elif w < 10.0:
            position_balance_label = "medium"
        else:
            position_balance_label = "heavy"
    else:
        position_balance_label = "held_unknown_size"

    return {
        "symbol": symbol,
        "price_usd": price_usd,
        "price_cad": price_cad,
        "fx_usdcad": fx_usdcad,
        "fx_meta": fx_meta,
        "position": position,
        "portfolio_value_usd": portfolio_value_usd,
        "position_value_usd": position_value_usd,
        "position_weight_pct": position_weight_pct,
        "position_balance_label": position_balance_label,
    }


def _load_recent_polygon_headlines(symbol: str, limit: int = 3) -> List[Dict[str, Any]]:
    import requests

    symbol = str(symbol or "").strip().upper()
    if not symbol:
        return []

    api_key = str(os.environ.get("POLYGON_API_KEY", "")).strip()
    if not api_key:
        env_path = Path("/etc/chad/polygon.env")
        if env_path.is_file():
            try:
                for raw in env_path.read_text(encoding="utf-8", errors="ignore").splitlines():
                    line = raw.strip()
                    if not line or line.startswith("#") or "=" not in line:
                        continue
                    k, v = line.split("=", 1)
                    if k.strip() == "POLYGON_API_KEY" and v.strip():
                        api_key = v.strip().strip('"').strip("'")
                        break
            except Exception:
                api_key = api_key

    if not api_key:
        return []

    try:
        resp = requests.get(
            "https://api.polygon.io/v2/reference/news",
            params={
                "ticker": symbol,
                "limit": max(1, min(int(limit), 5)),
                "order": "desc",
                "sort": "published_utc",
                "apiKey": api_key,
            },
            timeout=15,
        )
        if resp.status_code != 200:
            return []

        payload = resp.json()
        results = payload.get("results")
        if not isinstance(results, list):
            return []

        out: List[Dict[str, Any]] = []
        sym_low = symbol.lower()

        for item in results:
            if not isinstance(item, dict):
                continue

            title = str(item.get("title") or "").strip()
            desc = str(item.get("description") or "").strip()
            published = str(item.get("published_utc") or "").strip()

            hay = f"{title} {desc}".lower()
            relevance = 0
            if sym_low in hay:
                relevance += 2

            tickers = item.get("tickers")
            if isinstance(tickers, list):
                tickers_up = {str(t).strip().upper() for t in tickers if str(t).strip()}
                if symbol in tickers_up:
                    relevance += 3

            if not title:
                continue

            out.append(
                {
                    "title": title,
                    "published_utc": published,
                    "description_preview": desc[:160],
                    "relevance": relevance,
                }
            )

        out.sort(key=lambda x: (x.get("relevance", 0), x.get("published_utc", "")), reverse=True)
        return out[: max(1, min(int(limit), 3))]
    except Exception:
        return []


def get_coach_profile_from_request(request: "AdvisoryRequest") -> Dict[str, Any]:
    ctx = request.user_context if isinstance(request.user_context, dict) else {}
    profile = ctx.get("coach_profile")
    if isinstance(profile, dict):
        return profile
    return {}


def build_coaching_instructions(request: "AdvisoryRequest") -> str:
    profile = get_coach_profile_from_request(request)

    teaching_mode = bool(profile.get("teaching_mode", False))
    micro_lessons = bool(profile.get("micro_lessons", False))
    show_your_work = bool(profile.get("show_your_work", False))
    explain_like_im_10 = bool(profile.get("explain_like_im_10", False))
    audience_level = str(profile.get("audience_level", "general")).strip() or "general"
    tone = str(profile.get("tone", "standard")).strip() or "standard"

    if not teaching_mode:
        return (
            "- Use plain English\n"
            "- Keep it practical and concise\n"
            "- Avoid hype\n"
            "- Do not over-explain unless the user asks\n"
            "- Keep the answer tight"
        )

    lines = [
        "- The audience knows little or nothing about trading",
        "- You are in coaching mode, not analyst mode",
        "- Prefer very plain English over finance jargon",
        "- Keep sentences short and clean",
        "- If you use jargon, translate it in 3-5 simple words",
        "- Teach the thinking process, not just the answer",
        "- Use one simple metaphor when helpful",
        "- Be warm, calm, and confidence-building",
        "- Avoid sounding like Wall Street research",
        f"- Audience level: {audience_level}",
        f"- Tone mode: {tone}",
        "- Keep the answer SHORT",
        "- Use short sections with bold labels",
        "- Do not write long bull/bear essays unless absolutely necessary",
        "- Do not dump too many details at once",
        "- Sound like a smart coach helping a total beginner",
    ]

    if micro_lessons:
        lines.extend([
            "- Include one tiny lesson only",
            "- End with exactly one takeaway line that starts with: Why this matters:",
            "- Keep the takeaway short",
        ])

    if show_your_work:
        lines.extend([
            "- Include one very short line showing the logic",
            "- Example style: no strong trend + no big reason to rush = wait or buy small",
            "- Keep this logic line simple",
        ])

    if explain_like_im_10:
        lines.extend([
            "- Explain like the user is 10 years old but never talk down to them",
            "- Use very simple analogies from normal life",
            "- Replace technical phrases with everyday wording whenever possible",
        ])

    lines.extend([
        "- REQUIRED OUTPUT STRUCTURE:",
        "  **Simple answer**",
        "  one short paragraph max",
        "",
        "  **Why**",
        "  2 to 4 bullet-style lines max",
        "",
        "  **What to do**",
        "  2 to 4 bullet-style lines max",
        "",
        "  **Why this matters**",
        "  exactly one short line",
        "",
        "- If the user asks about buying a stock, be clear whether this looks better for short-term trading or long-term investing",
        "- If the user already owns the stock, mention concentration risk in simple words",
        "- Never end with a long ramble",
    ])

    return "\n".join(lines)


def normalize_to_primitive(obj: Any, *, depth: int = 0, max_depth: int = 6) -> Any:
    if depth > max_depth:
        return "<max_depth_exceeded>"

    if obj is None or isinstance(obj, (str, int, float, bool)):
        return obj

    if isinstance(obj, bytes):
        return obj.decode("utf-8", errors="replace")

    if is_dataclass(obj):
        return normalize_to_primitive(asdict(obj), depth=depth + 1, max_depth=max_depth)

    if isinstance(obj, Mapping):
        out: Dict[str, Any] = {}
        for k, v in obj.items():
            out[str(k)] = normalize_to_primitive(v, depth=depth + 1, max_depth=max_depth)
        return out

    if isinstance(obj, (list, tuple, set)):
        return [normalize_to_primitive(v, depth=depth + 1, max_depth=max_depth) for v in obj]

    if hasattr(obj, "__dict__"):
        try:
            return normalize_to_primitive(vars(obj), depth=depth + 1, max_depth=max_depth)
        except Exception:
            pass

    return repr(obj)


def make_error_payload(exc: BaseException) -> Dict[str, Any]:
    return {
        "error": {
            "type": type(exc).__name__,
            "message": str(exc),
            "traceback": traceback.format_exc(limit=8),
        }
    }


# ---------------------------------------------------------------------
# Data contracts
# ---------------------------------------------------------------------

@dataclass(frozen=True)
class AdvisoryRequest:
    symbol: str
    user_question: str
    horizon: str = "unspecified"
    risk_profile: str = "unspecified"
    user_context: Dict[str, Any] = field(default_factory=dict)


@dataclass(frozen=True)
class EngineSpec:
    name: str
    module_name: str
    candidate_functions: Tuple[str, ...]
    timeout_seconds: float = 10.0
    required: bool = False


@dataclass(frozen=True)
class EngineResult:
    name: str
    ok: bool
    module_name: str
    function_name: Optional[str]
    duration_ms: int
    data: Dict[str, Any]
    notes: List[str] = field(default_factory=list)


@dataclass(frozen=True)
class AdvisoryResult:
    ts_utc: str
    symbol: str
    user_question: str
    local_runtime_state: Dict[str, Any]
    engine_results: Dict[str, EngineResult]
    synthesis_model: Optional[str]
    synthesis_ok: bool
    analysis_text: str
    raw_prompt_preview: str
    diagnostics: Dict[str, Any]

    def to_dict(self) -> Dict[str, Any]:
        return {
            "ts_utc": self.ts_utc,
            "symbol": self.symbol,
            "user_question": self.user_question,
            "local_runtime_state": self.local_runtime_state,
            "engine_results": {k: asdict(v) for k, v in self.engine_results.items()},
            "synthesis_model": self.synthesis_model,
            "synthesis_ok": self.synthesis_ok,
            "analysis_text": self.analysis_text,
            "raw_prompt_preview": self.raw_prompt_preview,
            "diagnostics": self.diagnostics,
        }


# ---------------------------------------------------------------------
# OpenAI abstraction
# ---------------------------------------------------------------------

class LLMClient(Protocol):
    def synthesize(self, request: AdvisoryRequest, runtime_state: Dict[str, Any], engine_results: Dict[str, EngineResult]) -> Tuple[bool, str, Optional[str], str]:
        ...


class OpenAIAdvisoryClient:
    def __init__(
        self,
        *,
        model: Optional[str] = None,
        temperature: float = 0.2,
        max_prompt_chars: int = 120_000,
    ) -> None:
        env_model = (
            str(os.environ.get("CHAD_ADVISORY_OPENAI_MODEL", "")).strip()
            or str(os.environ.get("OPENAI_MODEL", "")).strip()
            or "gpt-5"
        )
        self._model = model or env_model
        self._temperature = float(temperature)
        self._max_prompt_chars = int(max_prompt_chars)

        api_key = str(os.environ.get("OPENAI_API_KEY", "")).strip()
        if OpenAI is None:
            self._client = None
        elif not api_key:
            self._client = None
        else:
            try:
                self._client = OpenAI(api_key=api_key)
            except Exception:
                self._client = None

    def synthesize(
        self,
        request: AdvisoryRequest,
        runtime_state: Dict[str, Any],
        engine_results: Dict[str, EngineResult],
    ) -> Tuple[bool, str, Optional[str], str]:
        prompt = self._build_prompt(request, runtime_state, engine_results)
        prompt_preview = truncate_text(prompt, 6000)

        if self._client is None:
            return False, self._fallback_text(request, runtime_state, engine_results, "openai_package_unavailable"), self._model, prompt_preview

        try:
            # Newer client path
            if hasattr(self._client, "responses"):
                resp = self._client.responses.create(
                    model=self._model,
                    input=prompt,
                )
                text = getattr(resp, "output_text", None)
                if isinstance(text, str) and text.strip():
                    return True, text.strip(), self._model, prompt_preview

            # Compatibility fallback
            if hasattr(self._client, "chat") and hasattr(self._client.chat, "completions"):
                resp = self._client.chat.completions.create(
                    model=self._model,
                    temperature=self._temperature,
                    messages=[
                        {"role": "system", "content": "You are CHAD's market advisory explainer. Be clear, direct, balanced, and risk-aware."},
                        {"role": "user", "content": prompt},
                    ],
                )
                text = resp.choices[0].message.content if resp.choices else None
                if isinstance(text, str) and text.strip():
                    return True, text.strip(), self._model, prompt_preview

            return False, self._fallback_text(request, runtime_state, engine_results, "openai_empty_response"), self._model, prompt_preview
        except Exception as exc:
            return False, self._fallback_text(request, runtime_state, engine_results, f"openai_error:{type(exc).__name__}:{exc}"), self._model, prompt_preview

    def _build_prompt(
        self,
        request: AdvisoryRequest,
        runtime_state: Dict[str, Any],
        engine_results: Dict[str, EngineResult],
    ) -> str:
        engine_payload = {
            name: {
                "ok": result.ok,
                "function_name": result.function_name,
                "duration_ms": result.duration_ms,
                "notes": result.notes,
                "data": result.data,
            }
            for name, result in engine_results.items()
        }

        coaching_instructions = build_coaching_instructions(request)
        live_context = _load_live_context(request.symbol)
        recent_headlines = _load_recent_polygon_headlines(request.symbol, limit=3)

        return truncate_text(
            f"""
You are CHAD's advisory synthesis layer.

Core job:
- Answer the user's question like a grounded market coach
- Be practical, not hype-driven
- Distinguish clearly between long-term investing and short-term trading
- Explain risks in simple English
- Avoid pretending certainty exists when it doesn't
- If the local brains disagree, say that plainly
- If data is incomplete, say what is missing
- Do not mention internal function names or code
- Do not expose secrets, env vars, stack traces, or file-system details unless relevant to trading logic

Coaching instructions:
{coaching_instructions}

LIVE CONTEXT TO USE IN THE ANSWER:
{safe_json_dumps(live_context)}

RECENT POLYGON HEADLINES TO USE IF RELEVANT:
{safe_json_dumps(recent_headlines)}

User request:
{safe_json_dumps(asdict(request))}

Local CHAD runtime state:
{safe_json_dumps(runtime_state)}

Engine outputs:
{safe_json_dumps(engine_payload)}

IMPORTANT SYNTHETIC ANALYST RULES:
- Treat engine_results.synthetic_analyst.data as a key decision layer
- Use synthetic_analyst.data.decision as the main action hint unless stronger evidence clearly overrides it
- Read synthetic_analyst.data.price_direction in plain words:
  - strong_up = going up strongly
  - up = going up
  - sideways = not moving clearly
  - down = drifting down
  - strong_down = falling hard
- Read synthetic_analyst.data.holding_balance_label in plain words:
  - none = user does not own it
  - small = user owns only a little
  - medium = user already owns a decent amount
  - heavy = user already owns a big amount
- Map synthetic analyst decisions into plain English:
  - buy = buy
  - buy_small = buy a little
  - hold = hold
  - wait = wait
  - trim = trim a little

REQUIRED ANSWER RULES:
- HARD LIMIT: aim for under 550 characters total
- Use very plain beginner English
- Speak like a smart money coach helping a total beginner
- Do not sound robotic or generic
- Sound like a sharp but simple money coach
- Prefer words like:
  - buy a little
  - wait
  - hold
  - sell a little
  - big reason
  - going up
  - going down
  - not moving clearly
  - slipping lately
  - moving sideways
- Avoid stiff phrases like:
  - for now
  - at this time
  - outlook
  - setup
  - conviction
- Start with only the shortest useful fact block
- If live_context has price_usd, show stock price in USD
- If live_context has price_cad, show stock price in CAD
- If live_context.position exists, say the share count only if it helps the decision and keeps the answer short
- If live_context.position is missing, clearly say the user does not currently own it
- Use live_context.position_balance_label exactly, but explain it in plain words:
  - small = small part of your account
  - medium = decent amount already
  - heavy = big amount already
  - none = you do not own it
- Be very clear about the decision: buy small / hold / wait / trim
- Never use these words by themselves:
  trend, neutral, catalyst, volatility, exposure, momentum, setup, conviction
- Replace them with simple language:
  - trend = price has been going up, down, or sideways
  - neutral = no clear push either way
  - catalyst = big reason price could move
  - volatility = price jumps around a lot
  - exposure = how much you already own
  - momentum = price has been moving strongly
  - setup = how it looks right now
  - conviction = how strong the case is
- Do not write long essays
- Do not repeat the same point in different words
- Keep the Why section to 2 bullets max
- Keep the What to do section to 1 bullet max
- Headlines section must be 1 very short bullet max
- If headlines are broad and not stock-specific, say that in plain English
- HARD STOP: do not add any extra section after 'Why this matters'
- HARD STOP: do not add extra summary lines after the final line
- HARD STOP: do not add logic lines after the final line
- HARD STOP: never add a line starting with 'Logic:'
- HARD STOP: never add a final formula line like:
  - no strong push + price dropping = wait
  - no clear push + already own enough = hold
- HARD STOP: after the 'Why this matters' line, output must end immediately
- HARD STOP: do not add any extra line after 'Why this matters'
- HARD STOP: maximum shape is:
  - Quick facts = 3 lines max
  - Call = 1 line
  - Why = 2 bullets max
  - Headline = 1 bullet max
  - Why this matters = 1 line
- Omit headline completely if weak
- Omit share count if it does not improve the answer
- Omit balance explanation if the hold line already makes it obvious
- Avoid these words unless immediately explained: uncertain, signal, confidence, specific, outlook
- Prefer these replacements:
  - uncertain = not clear yet
  - signal = sign
  - confidence = strength
  - specific = mainly about this company
  - outlook = what it looks like right now
- Use this style:
  - Balance: small = you own only a little
  - Balance: medium = you already own a decent amount
  - Balance: heavy = you already own a lot
  - Balance: none = you do not own it
- Do not write full sentences when a short phrase works
- Remove anything non-essential
- Avoid these words unless immediately explained: uncertain, signal, confidence, specific, outlook
- Prefer these replacements:
  - uncertain = not clear yet
  - signal = sign
  - confidence = strength
  - specific = mainly about this company
  - outlook = what it looks like right now
- Use this style:
  - Balance: small = you own only a little
  - Balance: medium = you already own a decent amount
  - Balance: heavy = you already own a lot
  - Balance: none = you do not own it
- Do not write full sentences when a short phrase works
- Remove anything non-essential

REQUIRED OUTPUT FORMAT:
Quick facts
Price: <USD / CAD if available>
You hold: <shares or none>
Balance: <plain English only>

Call
<hold / wait / buy small / trim>

Why
- <short line>
- <short line max>

Headline
- <one short line only if useful>

Why this matters
<one short line only>
""".strip(),
            self._max_prompt_chars,
        )

    def _fallback_text(
        self,
        request: AdvisoryRequest,
        runtime_state: Dict[str, Any],
        engine_results: Dict[str, EngineResult],
        reason: str,
    ) -> str:
        lines: List[str] = []
        lines.append(f"CHAD advisory fallback triggered: {reason}")
        lines.append("")
        lines.append(f"Question: {request.user_question}")
        lines.append(f"Symbol: {request.symbol}")
        lines.append("")

        shadow = runtime_state.get("scr_state", {})
        live_gate = runtime_state.get("live_gate", {})
        recon = runtime_state.get("reconciliation_state", {})

        lines.append("System state")
        lines.append(f"- SCR state: {shadow.get('state', 'unknown')}")
        lines.append(f"- Reconciliation: {recon.get('status', 'unknown')}")
        lines.append(f"- Live gate allow_ibkr_live: {live_gate.get('allow_ibkr_live', False)}")
        lines.append("")

        lines.append("Brain status")
        for name, result in engine_results.items():
            status = "OK" if result.ok else "ERROR"
            lines.append(f"- {name}: {status}")
        lines.append("")
        lines.append("OpenAI synthesis was unavailable, so this is a local fallback summary.")
        return "\n".join(lines).strip()


# ---------------------------------------------------------------------
# Engine resolver / runner
# ---------------------------------------------------------------------

def _symbol_candidates(symbol: str) -> List[str]:
    s = str(symbol or "").strip().upper()
    return [s] if s else []


@lru_cache(maxsize=128)
def import_module_cached(module_name: str):
    return importlib.import_module(module_name)


def resolve_callable(module_name: str, candidate_functions: Sequence[str]) -> Tuple[Optional[Callable[..., Any]], Optional[str], List[str]]:
    notes: List[str] = []
    try:
        module = import_module_cached(module_name)
    except Exception as exc:
        notes.append(f"module_import_failed:{type(exc).__name__}:{exc}")
        return None, None, notes

    for fn_name in candidate_functions:
        fn = getattr(module, fn_name, None)
        if callable(fn):
            notes.append(f"resolved:{module_name}.{fn_name}")
            return fn, fn_name, notes

    exported = sorted(name for name in dir(module) if callable(getattr(module, name, None)) and not name.startswith("_"))
    notes.append(f"callable_not_found:candidates={list(candidate_functions)} exports={exported[:40]}")
    return None, None, notes


def build_engine_call_kwargs(fn: Callable[..., Any], request: AdvisoryRequest) -> Dict[str, Any]:
    sig = inspect.signature(fn)
    kwargs: Dict[str, Any] = {}

    candidate_values = {
        "symbol": request.symbol,
        "ticker": request.symbol,
        "asset": request.symbol,
        "question": request.user_question,
        "prompt": request.user_question,
        "query": request.user_question,
        "user_question": request.user_question,
        "request": request,
        "horizon": request.horizon,
        "risk_profile": request.risk_profile,
        "user_context": request.user_context,
        "context": request.user_context,
    }

    for name, param in sig.parameters.items():
        if name in candidate_values:
            kwargs[name] = candidate_values[name]
        elif param.default is inspect.Parameter.empty:
            # Do not guess arbitrary required params.
            # Leave unresolved and let caller decide whether to invoke.
            pass

    return kwargs



def adapt_engine_call(fn_name: str, request: AdvisoryRequest) -> Tuple[Dict[str, Any], bool]:
    """
    Return (kwargs, handled) for known engine call signatures that do not match the
    generic symbol/question convention.
    """
    if fn_name == "run_research_scenario_from_request":
        timeframe_map = {
            "short_term": "1w",
            "swing": "1m",
            "medium_term": "1m",
            "long_term": "3m",
            "investment": "3m",
            "unspecified": "1m",
            "": "1m",
        }
        scenario_timeframe = timeframe_map.get(str(request.horizon).strip().lower(), "1m")

        try:
            mod = import_module_cached("chad.intel.research_engine")
            req_cls = getattr(mod, "ResearchRequestInput", None)
            if req_cls is not None:
                req_obj = req_cls(
                    symbol=request.symbol,
                    scenario_timeframe=scenario_timeframe,
                    question=request.user_question,
                )
                return ({"request": req_obj}, True)
        except Exception:
            pass

        payload = {
            "symbol": request.symbol,
            "scenario_timeframe": scenario_timeframe,
            "question": request.user_question,
        }
        return ({"request": payload}, True)

    if fn_name == "run_research_scenario":
        context_parts = []
        if str(request.user_question).strip():
            context_parts.append(f"User question: {request.user_question}")
        if str(request.horizon).strip() and str(request.horizon).strip().lower() != "unspecified":
            context_parts.append(f"Horizon: {request.horizon}")
        if str(request.risk_profile).strip() and str(request.risk_profile).strip().lower() != "unspecified":
            context_parts.append(f"Risk profile: {request.risk_profile}")

        context = "\n".join(context_parts).strip()

        payload = {
            "symbol": request.symbol,
            "context": context,
        }
        return (payload, True)

    if fn_name == "build_risk_explanation":
        return ({}, True)

    if fn_name == "build_synthetic_analyst":
        return ({"symbol": request.symbol}, True)

    if fn_name == "render_risk_summary_text":
        return ({}, False)

    return ({}, False)


def can_call_with_kwargs(fn: Callable[..., Any], kwargs: Dict[str, Any]) -> bool:
    try:
        inspect.signature(fn).bind_partial(**kwargs)
        # Still need all required args satisfied
        sig = inspect.signature(fn)
        for name, p in sig.parameters.items():
            if p.default is inspect.Parameter.empty and p.kind in (
                inspect.Parameter.POSITIONAL_ONLY,
                inspect.Parameter.POSITIONAL_OR_KEYWORD,
                inspect.Parameter.KEYWORD_ONLY,
            ):
                if name not in kwargs:
                    return False
        return True
    except Exception:
        return False


class EngineRunner:
    def __init__(self, specs: Sequence[EngineSpec], *, max_workers: int = 5) -> None:
        self._specs = list(specs)
        self._max_workers = max(1, int(max_workers))

    def run_all(self, request: AdvisoryRequest) -> Dict[str, EngineResult]:
        results: Dict[str, EngineResult] = {}
        lock = threading.Lock()

        def _run_one(spec: EngineSpec) -> None:
            started = datetime.now(timezone.utc)

            fn, fn_name, resolve_notes = resolve_callable(spec.module_name, spec.candidate_functions)
            if fn is None:
                result = EngineResult(
                    name=spec.name,
                    ok=False,
                    module_name=spec.module_name,
                    function_name=None,
                    duration_ms=0,
                    data={"error": {"message": "callable_resolution_failed"}},
                    notes=resolve_notes,
                )
                with lock:
                    results[spec.name] = result
                return

            adapted_kwargs, handled = adapt_engine_call(fn_name or "", request)
            kwargs = adapted_kwargs if handled else build_engine_call_kwargs(fn, request)

            if not can_call_with_kwargs(fn, kwargs):
                result = EngineResult(
                    name=spec.name,
                    ok=False,
                    module_name=spec.module_name,
                    function_name=fn_name,
                    duration_ms=0,
                    data={"error": {"message": "required_parameters_not_satisfied", "provided_kwargs": sorted(kwargs.keys())}},
                    notes=resolve_notes,
                )
                with lock:
                    results[spec.name] = result
                return

            data: Dict[str, Any]
            ok = False
            notes = list(resolve_notes)

            try:
                with ThreadPoolExecutor(max_workers=1) as inner_pool:
                    fut = inner_pool.submit(fn, **kwargs)
                    raw = fut.result(timeout=spec.timeout_seconds)
                data = normalize_to_primitive(raw)
                if fn_name == "build_risk_explanation":
                    if isinstance(data, dict):
                        rendered = None
                        try:
                            risk_mod = import_module_cached("chad.intel.risk_explainer")
                            render_fn = getattr(risk_mod, "render_risk_summary_text", None)
                            if callable(render_fn):
                                rendered = render_fn(raw)
                        except Exception:
                            rendered = None
                        if rendered:
                            data = {
                                "summary_text": str(rendered),
                                "explanation": data,
                            }
                        else:
                            data = {"explanation": data}
                    else:
                        data = {"result": data}
                elif not isinstance(data, dict):
                    data = {"result": data}

                ok = "error" not in data
            except FuturesTimeoutError:
                data = {"error": {"message": f"engine_timeout_after_{spec.timeout_seconds}s"}}
                notes.append("timeout")
                ok = False
            except Exception as exc:
                data = make_error_payload(exc)
                ok = False

            duration_ms = int((datetime.now(timezone.utc) - started).total_seconds() * 1000)
            result = EngineResult(
                name=spec.name,
                ok=ok,
                module_name=spec.module_name,
                function_name=fn_name,
                duration_ms=duration_ms,
                data=data,
                notes=notes,
            )
            with lock:
                results[spec.name] = result

        with ThreadPoolExecutor(max_workers=self._max_workers) as pool:
            futures = [pool.submit(_run_one, spec) for spec in self._specs]
            for fut in futures:
                fut.result()

        return results


# ---------------------------------------------------------------------
# Runtime state collector
# ---------------------------------------------------------------------

class RuntimeStateProvider:
    def __init__(self, root: Optional[Path] = None) -> None:
        self._runtime_dir = (root or runtime_dir()).resolve()

    def collect(self) -> Dict[str, Any]:
        files = {
            "positions_snapshot": self._runtime_dir / "positions_snapshot.json",
            "reconciliation_state": self._runtime_dir / "reconciliation_state.json",
            "scr_state": self._runtime_dir / "scr_state.json",
            "dynamic_caps": self._runtime_dir / "dynamic_caps.json",
            "live_readiness": self._runtime_dir / "live_readiness.json",
            "positions_truth": self._runtime_dir / "positions_truth.json",
            "trade_lifecycle_state": self._runtime_dir / "trade_lifecycle_state.json",
            "feed_state": self._runtime_dir / "feed_state.json",
        }

        out = {
            name: read_json_dict(path)
            for name, path in files.items()
        }

        # Try local API-derived snapshot only if present in runtime or if a local mirror exists.
        # This keeps the module file-safe and network-optional.
        live_gate_path = self._runtime_dir / "live_gate_snapshot.json"
        out["live_gate"] = read_json_dict(live_gate_path)

        return normalize_to_primitive(out)


