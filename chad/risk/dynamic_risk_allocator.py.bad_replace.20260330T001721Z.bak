"""
Advanced Dynamic Risk Allocator
===============================

This module implements a high‑performance, production‑grade dynamic risk
allocation engine suitable for algorithmic trading systems.  It is designed
using modern Python features and proven architectural patterns:

* **Dependency Injection & Strategy Pattern** – Risk allocation logic is
  encapsulated in strategies that can be swapped at runtime.  Data
  acquisition is injected via provider classes so components remain
  loosely coupled and testable.
* **Asynchronous I/O & Concurrency** – Input sources (equity, exposures,
  profit lock) are loaded concurrently using `asyncio.to_thread` for
  efficient non‑blocking file access.  Structured concurrency via
  `asyncio.gather` ensures all tasks complete or clean up correctly.
* **Robust Error Handling** – All external interactions are wrapped in
  try/except blocks to guarantee the allocator never crashes.  Missing
  or malformed data results in safe defaults and informative log
  messages rather than uncaught exceptions.
* **Atomic Output** – Dynamic caps are written to disk atomically via a
  temporary file and rename, ensuring downstream processes never see
  partially written data.
* **Type Hints & Documentation** – Comprehensive type annotations and
  docstrings aid maintainability.  The code follows single
  responsibility principles and is extensively documented.

The allocator adjusts portfolio risk based on available capital and
profit‑lock status.  When the profit lock module signals elevated
profit, this engine scales down the allowable risk according to the
configured sizing factors.  If a hard stop is triggered, risk caps are
reduced to zero.  Risk is then allocated across individual strategies
according to a pluggable weighting scheme.

Usage example:

```bash
python improved_dynamic_risk_allocator.py \
  --equity runtime/dynamic_caps.json \
  --profit-lock runtime/profit_lock_state.json \
  --exposures runtime/exposures.json \
  --risk-fraction 0.02 \
  --strategy exposure_weighted \
  --out runtime/dynamic_caps.json
```

The above will read the current equity from the specified file,
retrieve profit lock state, compute a 2 % risk budget, and allocate
risk according to the relative exposures in `exposures.json`.  It
writes the resulting dynamic caps back to `runtime/dynamic_caps.json`.

References
----------

This implementation follows modern Python concurrency best practices and
design patterns as recommended by Applifting’s guide on structured
concurrency【363097455038250†L34-L44】【363097455038250†L88-L104】.  Risk management
logic is inspired by PyQuant News’ discussion of controlling drawdowns
and allocating risk using numerical libraries【346953769569549†L69-L79】.  The
overall architecture takes inspiration from Refactoring.Guru’s catalog
of design patterns【284227234557433†L9-L17】.
"""

from __future__ import annotations

import argparse
import asyncio
import json
import logging
import os
import tempfile
from dataclasses import dataclass
from datetime import datetime, timezone
from enum import Enum
from functools import cached_property
from pathlib import Path
from typing import Any, Awaitable, Callable, Dict, Iterable, List, Optional


# ---------------------------------------------------------------------------
# Logging configuration
#
# Configured at module import to avoid missing log messages.  The log level
# can be overridden via the CLI.  Logging is intentionally lightweight to
# minimise overhead in high‑frequency contexts.
logging.basicConfig(
    format="%(asctime)s %(levelname)s %(name)s: %(message)s",
    level=logging.INFO,
)
logger = logging.getLogger(__name__)


# ---------------------------------------------------------------------------
# Data models

@dataclass(frozen=True)
class ProfitLockState:
    """Represents the output of the profit lock system.

    Attributes
    ----------
    sizing_factor:
        Multiplier for the risk budget.  A value between 0 and 1
        indicates capital conservation; 1 means no adjustment.  A
        value of 0 stops all new positions.
    stop_new_entries:
        Whether the system should disallow new entries entirely.  When
        true, the risk budget is set to zero regardless of the
        sizing factor.
    explain:
        Human‑readable description of the current profit lock state.
    """

    sizing_factor: float = 1.0
    stop_new_entries: bool = False
    explain: str = "profit lock inactive"


@dataclass(frozen=True)
class AllocationResult:
    """Structured representation of dynamic caps output."""

    ts: str
    equity: float
    risk_budget: float
    sizing_factor: float
    stop_new_entries: bool
    caps: Dict[str, float]
    explain: str


# ---------------------------------------------------------------------------
# Provider abstractions

class EquityProvider:
    """Abstract base class for obtaining available capital.

    Concrete subclasses implement asynchronous retrieval of the latest
    equity value.  A provider returns ``None`` if the source cannot
    supply a valid number.
    """

    async def get_equity(self) -> Optional[float]:
        raise NotImplementedError


class ProfitLockProvider:
    """Abstract base class for retrieving profit lock state."""

    async def get_profit_lock(self) -> ProfitLockState:
        raise NotImplementedError


class ExposureProvider:
    """Abstract base class for retrieving relative weights for risk allocation."""

    async def get_exposures(self) -> Dict[str, float]:
        raise NotImplementedError


class FileEquityProvider(EquityProvider):
    """Reads equity from a JSON file.

    The provider expects the given path to be a JSON file with a
    numeric field.  The default key is ``total_equity`` but can be
    overridden.  If the file or field is missing, ``get_equity``
    returns ``None``.
    """

    def __init__(self, path: Path, keys: Iterable[str] = ("total_equity",)):
        self.path = path
        self.keys = list(keys)

    async def get_equity(self) -> Optional[float]:
        if not self.path.is_file():
            logger.warning("Equity file %s does not exist", self.path)
            return None
        try:
            data = await asyncio.to_thread(self.path.read_text, encoding="utf-8")
            obj = json.loads(data)
            for key in self.keys:
                if key in obj:
                    value = obj[key]
                    try:
                        eq = float(value)
                        if eq > 0:
                            return eq
                    except (TypeError, ValueError):
                        continue
        except Exception as exc:
            logger.exception("Failed to read equity from %s: %s", self.path, exc)
        return None


class ChainEquityProvider(EquityProvider):
    """Tries multiple providers in sequence and returns the first valid equity."""

    def __init__(self, providers: Iterable[EquityProvider]):
        self.providers = list(providers)

    async def get_equity(self) -> Optional[float]:
        for provider in self.providers:
            value = await provider.get_equity()
            if value is not None and value > 0:
                return value
        return None


class JsonProfitLockProvider(ProfitLockProvider):
    """Reads profit lock state from a JSON file.

    The expected format is the output generated by the profit lock module.
    If unavailable or malformed, defaults to an inactive profit lock.
    """

    def __init__(self, path: Path):
        self.path = path

    @cached_property
    def _default_state(self) -> ProfitLockState:
        return ProfitLockState()

    async def get_profit_lock(self) -> ProfitLockState:
        if not self.path.is_file():
            logger.info("Profit lock file %s not found; assuming inactive", self.path)
            return self._default_state
        try:
            raw = await asyncio.to_thread(self.path.read_text, encoding="utf-8")
            state = json.loads(raw)
            sizing_factor = float(state.get("sizing_factor", 1.0))
            stop_new = bool(state.get("stop_new_entries", False))
            explain = str(state.get("explain", ""))
            # Normalise factor to sane range
            sizing_factor = max(0.0, min(1.0, sizing_factor))
            return ProfitLockState(sizing_factor=sizing_factor, stop_new_entries=stop_new, explain=explain)
        except Exception as exc:
            logger.exception("Error parsing profit lock state %s: %s", self.path, exc)
            return self._default_state


class JsonExposureProvider(ExposureProvider):
    """Reads relative exposure weights from a JSON file.

    The file should map strategy names to numeric exposure values.  These
    values need not sum to 1; the allocator will normalise them.
    If the file is missing or malformed, returns an empty mapping.
    """

    def __init__(self, path: Path):
        self.path = path

    async def get_exposures(self) -> Dict[str, float]:
        if not self.path.is_file():
            logger.warning("Exposure file %s does not exist", self.path)
            return {}
        try:
            text = await asyncio.to_thread(self.path.read_text, encoding="utf-8")
            data = json.loads(text)
            if not isinstance(data, dict):
                return {}
            exposures: Dict[str, float] = {}
            for k, v in data.items():
                try:
                    exposures[str(k)] = float(v)
                except (TypeError, ValueError):
                    continue
            return exposures
        except Exception as exc:
            logger.exception("Failed to read exposures from %s: %s", self.path, exc)
            return {}


# ---------------------------------------------------------------------------
# Risk allocation strategies

class RiskStrategy(Enum):
    """Enumeration of available risk allocation strategies."""

    EQUAL_WEIGHT = "equal_weight"
    EXPOSURE_WEIGHTED = "exposure_weighted"

    @staticmethod
    def from_string(name: str) -> "RiskStrategy":
        for strat in RiskStrategy:
            if strat.value == name:
                return strat
        raise ValueError(f"Unknown strategy '{name}'")


class BaseRiskAllocator:
    """Abstract base class for risk allocators."""

    async def allocate(
        self,
        total_budget: float,
        exposures: Dict[str, float],
    ) -> Dict[str, float]:
        raise NotImplementedError


class EqualWeightAllocator(BaseRiskAllocator):
    """Allocates risk equally across all keys.

    This strategy ignores the provided exposure values and divides the
    available risk budget evenly across all non‑empty keys.  Keys with
    zero or negative exposure are included, ensuring every strategy
    receives the same risk cap.
    """

    async def allocate(
        self,
        total_budget: float,
        exposures: Dict[str, float],
    ) -> Dict[str, float]:
        keys = list(exposures.keys())
        if not keys:
            return {}
        per = total_budget / len(keys)
        return {k: per for k in keys}


class ExposureWeightedAllocator(BaseRiskAllocator):
    """Allocates risk proportionally to exposure values.

    Weights are normalised so that the sum of caps equals the total
    budget.  Negative or NaN exposures are treated as zero.
    """

    async def allocate(
        self,
        total_budget: float,
        exposures: Dict[str, float],
    ) -> Dict[str, float]:
        # Filter and normalise exposures
        cleaned: Dict[str, float] = {}
        for k, v in exposures.items():
            try:
                val = float(v)
                if val < 0 or not val:
                    continue
                cleaned[k] = val
            except (TypeError, ValueError):
                continue
        if not cleaned:
            # Fallback to equal weighting if exposures empty or invalid
            return await EqualWeightAllocator().allocate(total_budget, exposures)
        total = sum(cleaned.values())
        caps: Dict[str, float] = {}
        for k, v in cleaned.items():
            weight = v / total
            caps[k] = total_budget * weight
        # Include strategies with zero weight but present in exposures
        for k in exposures.keys():
            caps.setdefault(k, 0.0)
        return caps


def risk_allocator_factory(strategy: RiskStrategy) -> BaseRiskAllocator:
    """Factory function returning an allocator instance for the given strategy."""
    if strategy is RiskStrategy.EQUAL_WEIGHT:
        return EqualWeightAllocator()
    if strategy is RiskStrategy.EXPOSURE_WEIGHTED:
        return ExposureWeightedAllocator()
    raise ValueError(f"Unsupported strategy {strategy}")


# ---------------------------------------------------------------------------
# Dynamic Risk Allocator Engine

class DynamicRiskAllocator:
    """Coordinates the risk allocation process.

    This class encapsulates the full workflow from data acquisition to
    risk allocation and output generation.  It is designed to be
    reusable and testable.  Providers and configuration are injected
    via the constructor.
    """

    def __init__(
        self,
        equity_provider: EquityProvider,
        profit_lock_provider: ProfitLockProvider,
        exposure_provider: ExposureProvider,
        risk_fraction: float,
        strategy: RiskStrategy,
    ) -> None:
        self.equity_provider = equity_provider
        self.profit_lock_provider = profit_lock_provider
        self.exposure_provider = exposure_provider
        self.risk_fraction = max(0.0, float(risk_fraction))
        self.strategy = strategy

    async def execute(self) -> AllocationResult:
        """Runs the allocation pipeline and returns a structured result."""
        # Concurrently retrieve all inputs
        equity_task = asyncio.create_task(self.equity_provider.get_equity())
        profit_lock_task = asyncio.create_task(self.profit_lock_provider.get_profit_lock())
        exposures_task = asyncio.create_task(self.exposure_provider.get_exposures())
        # Wait for all
        equity, pl_state, exposures = await asyncio.gather(
            equity_task, profit_lock_task, exposures_task
        )
        if equity is None or equity <= 0:
            raise ValueError("Failed to obtain positive equity value")
        # Compute base risk budget
        risk_budget = equity * self.risk_fraction
        # Apply profit lock adjustments
        sizing_factor = pl_state.sizing_factor
        stop_new = pl_state.stop_new_entries
        adjusted_budget = risk_budget * sizing_factor
        if stop_new:
            adjusted_budget = 0.0
        # Allocate across strategies using selected allocator
        allocator = risk_allocator_factory(self.strategy)
        caps = await allocator.allocate(adjusted_budget, exposures)
        # Timestamp in ISO 8601 UTC
        ts = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
        return AllocationResult(
            ts=ts,
            equity=equity,
            risk_budget=risk_budget,
            sizing_factor=sizing_factor,
            stop_new_entries=stop_new,
            caps=caps,
            explain=pl_state.explain,
        )

    @staticmethod
    def atomic_write(path: Path, payload: Dict[str, Any]) -> None:
        """Writes JSON payload atomically to the given path.

        Data is first written to a temporary file and then replaced
        atomically.  This prevents readers from seeing incomplete
        writes and works across POSIX file systems.
        """
        path.parent.mkdir(parents=True, exist_ok=True)
        fd, tmp_name = tempfile.mkstemp(prefix=path.name, suffix=".tmp", dir=str(path.parent))
        try:
            with os.fdopen(fd, "w", encoding="utf-8") as handle:
                json.dump(payload, handle, indent=2, sort_keys=True)
                handle.write("\n")
                handle.flush()
                os.fsync(handle.fileno())
            os.replace(tmp_name, path)
        finally:
            if os.path.exists(tmp_name):
                try:
                    os.unlink(tmp_name)
                except OSError:
                    pass


# ---------------------------------------------------------------------------
# Command‑line interface

def _parse_args(args: Optional[Iterable[str]] = None) -> argparse.Namespace:
    """Parse CLI arguments and return a namespace."""
    parser = argparse.ArgumentParser(description="Compute dynamic risk caps with profit lock integration.")
    parser.add_argument(
        "--equity",
        action="append",
        metavar="PATH",
        help="Path to a JSON file containing equity data.  The first valid file wins.  Can be specified multiple times.",
    )
    parser.add_argument(
        "--profit-lock",
        metavar="PATH",
        required=True,
        help="Path to the profit lock state JSON file.",
    )
    parser.add_argument(
        "--exposures",
        metavar="PATH",
        required=True,
        help="Path to the exposures JSON file.",
    )
    parser.add_argument(
        "--risk-fraction",
        type=float,
        default=float(os.getenv("CHAD_RISK_FRACTION", "0.02")),
        help="Fraction of equity to risk per day (e.g., 0.02 for 2 %).",
    )
    parser.add_argument(
        "--strategy",
        default="exposure_weighted",
        help="Risk allocation strategy: 'equal_weight' or 'exposure_weighted'.",
    )
    parser.add_argument(
        "--out",
        metavar="PATH",
        required=True,
        help="Output path for the dynamic caps JSON.",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Enable debug logging.",
    )
    return parser.parse_args(args)


async def _run_cli() -> None:
    ns = _parse_args()
    if ns.verbose:
        logger.setLevel(logging.DEBUG)
    # Build equity provider chain
    if not ns.equity:
        raise SystemExit("At least one --equity file must be provided")
    providers: List[EquityProvider] = []
    for e_path in ns.equity:
        providers.append(FileEquityProvider(Path(e_path)))
    equity_provider = ChainEquityProvider(providers)
    profit_lock_provider = JsonProfitLockProvider(Path(ns.profit_lock))
    exposure_provider = JsonExposureProvider(Path(ns.exposures))
    try:
        strategy = RiskStrategy.from_string(ns.strategy)
    except ValueError as exc:
        raise SystemExit(str(exc))
    allocator = DynamicRiskAllocator(
        equity_provider=equity_provider,
        profit_lock_provider=profit_lock_provider,
        exposure_provider=exposure_provider,
        risk_fraction=ns.risk_fraction,
        strategy=strategy,
    )
    result = await allocator.execute()
    # Prepare JSON payload for dynamic caps file
    payload = {
        "ts": result.ts,
        "equity": result.equity,
        "risk_budget": result.risk_budget,
        "sizing_factor": result.sizing_factor,
        "stop_new_entries": result.stop_new_entries,
        "caps": result.caps,
        "explain": result.explain,
    }
    out_path = Path(ns.out)
    DynamicRiskAllocator.atomic_write(out_path, payload)
    logger.info(
        "Wrote dynamic caps to %s (budget=%.2f, factor=%.2f, hard_stop=%s)",
        out_path,
        result.risk_budget,
        result.sizing_factor,
        result.stop_new_entries,
    )


def main() -> None:
    """Entry point when executed as a script."""
    try:
        asyncio.run(_run_cli())
    except Exception as exc:
        logger.critical("Fatal error: %s", exc)
        raise


if __name__ == "__main__":
    main()
